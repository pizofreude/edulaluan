# Supabase Cloud Configuration
# Get these from: https://app.supabase.com/project/_/settings/api
# 
# NEW API Key Model (2025/2026):
# - Publishable keys replace legacy anon keys (for client-side)
# - Secret keys replace legacy service_role keys (for server-side)
# - Legacy keys still work but will be removed in late 2026

# =============================================================================
# REQUIRED: Replace with your Supabase Cloud project values
# =============================================================================

# Your Supabase Cloud project URL (format: https://xxxxx.supabase.co)
PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# =============================================================================
# NEW API Key Model (Recommended for 2025/2026)
# =============================================================================
# Publishable Key (client-side/frontend - safe to expose)
# Replaces: PUBLIC_SUPABASE_ANON_KEY
# Get from: Settings → API → Project API keys → publishable key
PUBLIC_SUPABASE_PUBLISHABLE_KEY=pk_your-publishable-key-here

# Secret Key (server-side/backend - NEVER expose to client)
# Replaces: SUPABASE_SERVICE_ROLE_KEY
# Get from: Settings → API → Project API keys → secret key
# Format: sk_xxxxxxxxxxxxx
SUPABASE_SECRET_KEY=sk_your-secret-key-here

# =============================================================================
# Legacy API Keys (Still supported until late 2026)
# =============================================================================
# If you haven't migrated to the new key model yet, use these instead:

# Legacy Anon Key (client-side) - FOR BACKWARD COMPATIBILITY
# PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Legacy Service Role Key (server-side) - FOR BACKWARD COMPATIBILITY
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# =============================================================================
# For Netlify Deployment (set these in Netlify dashboard)
# =============================================================================
# Environment variables to add on Netlify:
# - PUBLIC_SUPABASE_URL
# - PUBLIC_SUPABASE_PUBLISHABLE_KEY
# - SUPABASE_SECRET_KEY
# 
# Or use the Netlify CLI:
# npx netlify env:set PUBLIC_SUPABASE_URL https://your-project-ref.supabase.co
# npx netlify env:set PUBLIC_SUPABASE_PUBLISHABLE_KEY pk_your-publishable-key
# npx netlify env:set SUPABASE_SECRET_KEY sk_your-secret-key
# =============================================================================

# =============================================================================
# Callout Feedback Widget (https://withcallout.com)
# Get your Project ID from: Dashboard > Your Application > Settings > Project ID
# =============================================================================
PUBLIC_CALLOUT_PROJECT_ID=your-project-id-here

# =============================================================================
# SETUP INSTRUCTIONS:
# =============================================================================
# 1. Go to https://supabase.com and create/sign in to your project
# 2. Copy your project URL (Settings → General → Project URL)
# 3. Copy your PUBLISHABLE key (Settings → API → Project API keys → publishable)
# 4. Copy your SECRET key (Settings → API → Project API keys → secret)
# 5. Replace the values above
# 6. Run migrations on cloud:
#    npx supabase login
#    npx supabase link --project-ref your-project-ref
#    npx supabase db push
# 7. Restart dev server: npm run dev
# =============================================================================
