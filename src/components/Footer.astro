        <p class="text-sm text-muted-foreground">
          Smart education resource navigator for Malaysian B40, M40 & T20 communities.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h3 class="text-lg font-semibold text-foreground mb-3">Quick Links</h3>
        <ul class="space-y-2">
          <li>
            <a href="/" class="footer-link group inline-flex items-center gap-1.5">
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
              <span>Home</span>
            </a>
          </li>
          <li>
            <a href="/navigate" class="footer-link group inline-flex items-center gap-1.5">
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
              <span>Navigate</span>
            </a>
          </li>
          <li>
            <a href="/resources" class="footer-link group inline-flex items-center gap-1.5">
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
              <span>Resources</span>
            </a>
          </li>
          <li>
            <a href="/about" class="footer-link group inline-flex items-center gap-1.5">
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
              <span>About</span>
            </a>
          </li>
          <li>
            <a href="/brand" class="footer-link group inline-flex items-center gap-1.5">
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
