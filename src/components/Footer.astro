      </div>
    </div>

    <div class="mt-8 pt-8 border-t text-center text-sm text-muted-foreground">
      <p>&copy; {new Date().getFullYear()} EduLaluan. Licensed under Apache 2.0.</p>
      <p class="mt-1">Built for Krackathon & GodamSahur - Empowering Malaysian communities through education.</p>
    </div>
  </div>
</footer>

<style>
  .footer-link {
    @apply text-sm text-muted-foreground transition-all duration-200 ease-out relative;
  }
  
  /* Desktop hover effect */
  @media (hover: hover) {
    .footer-link:hover {
      color: #0d9488;
    }
    
    .footer-link:hover::after {
      width: 100%;
    }
  }
  
  /* Mobile tap/active effect */
  .footer-link:active,
  .footer-link:focus-visible {
    color: #0d9488;
    transform: scale(1.02);
  }
  
  /* Underline animation */
  .footer-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    height: 2px;
    background-color: #0d9488;
    width: 0;
    transition: width 0.3s ease-out;
  }
  
  /* Mobile: show underline on current page (if needed) */
  .footer-link.active {
    color: #0d9488;
    font-weight: 500;
  }
  
  .footer-link.active::after {
    width: 100%;
  }
  
  /* Touch feedback for mobile */
  @media (hover: none) {
    .footer-link {
      padding-top: 4px;
      padding-bottom: 4px;
      margin-top: -4px;
      margin-bottom: -4px;
    }
    
    .footer-link:active {
      background-color: rgba(13, 148, 136, 0.1);
      border-radius: 4px;
    }
  }
</style>
