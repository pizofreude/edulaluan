---
// Hero component for landing page
// Redesigned with Modern Malaysian Education aesthetics
---

<section class="relative min-h-[90vh] flex items-center overflow-hidden bg-gradient-to-br from-primary via-primary/95 to-primary-dark">
  <!-- Batik Diamond Grid Background Pattern (subtle) -->
  <div class="absolute inset-0 opacity-[0.03]" aria-hidden="true">
    <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="heroDiamond" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
          <path d="M20 0 L40 20 L20 40 L0 20 Z" fill="none" stroke="white" strokeWidth="1" />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#heroDiamond)" />
    </svg>
  </div>

  <!-- Flowing Wave Accent (bottom left) -->
  <div class="absolute bottom-0 left-0 w-64 h-32 opacity-10 text-accent" aria-hidden="true">
    <svg width="100%" height="100%" viewBox="0 0 200 40" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0 20 Q25 0 50 20 T100 20 T150 20 T200 20" fill="none" stroke="currentColor" strokeWidth="2" />
      <path d="M0 25 Q25 5 50 25 T100 25 T150 25 T200 25" fill="none" stroke="currentColor" strokeWidth="1" />
    </svg>
  </div>

  <div class="container relative mx-auto px-4 sm:px-6 lg:px-8 py-section-md">
    <div class="max-w-4xl">
      <!-- Animated reveal wrapper -->
      <div class="animate-fade-in-up">
        <!-- Eyebrow text with accent -->
        <p class="text-sm md:text-base font-medium text-accent-light mb-4 tracking-wide uppercase">
          Smart Education Navigator
        </p>

        <!-- Main headline with distinctive typography -->
        <h1 class="font-display text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold mb-6 leading-tight tracking-tight">
          Find Your Path to
          <span class="block text-accent mt-2">Education Success</span>
        </h1>

        <!-- Subheadline -->
        <p class="text-lg md:text-xl lg:text-2xl mb-8 text-white/90 max-w-2xl leading-relaxed">
          Discover scholarships, free courses, and educational resources tailored for Malaysian B40, M40 & T20 communities.
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 mb-12">
          <a
            href="/navigate"
            class="group inline-flex items-center justify-center px-8 py-4 bg-accent hover:bg-accent-light text-accent-foreground font-semibold rounded-lg shadow-xl transition-all duration-300 hover:shadow-2xl hover:scale-105"
          >
            Start Navigating
            <svg class="ml-2 h-5 w-5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
          <a
            href="/resources"
            class="inline-flex items-center justify-center px-8 py-4 bg-white/10 hover:bg-white/20 text-white font-semibold rounded-lg border-2 border-white/30 backdrop-blur-sm transition-all duration-300 hover:border-white/50"
          >
            Browse Resources
          </a>
        </div>

        <!-- Trust indicators with decorative divider -->
        <div class="flex items-center gap-6 text-sm text-white/70">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-accent" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
            <span>138+ Resources</span>
          </div>
          <div class="w-px h-4 bg-white/30" aria-hidden="true"></div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-accent" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span>Free & Subsidized Options</span>
          </div>
          <div class="w-px h-4 bg-white/30" aria-hidden="true"></div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-accent" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z" />
            </svg>
            <span>For All Malaysians</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Decorative bottom wave transition -->
  <div class="absolute bottom-0 left-0 right-0 h-16 md:h-24 pointer-events-none" aria-hidden="true">
    <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full" preserveAspectRatio="none">
      <path d="M0 80L60 65C120 50 240 20 360 12.5C480 5 600 12.5 720 20C840 27.5 960 35 1080 42.5C1200 50 1320 57.5 1380 61.3L1440 65V80H1380C1320 80 1200 80 1080 80C960 80 840 80 720 80C600 80 480 80 360 80C240 80 120 80 60 80H0Z" fill="oklch(0.97 0.01 180)"/>
    </svg>
  </div>
</section>
