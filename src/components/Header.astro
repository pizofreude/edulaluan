---
// Header component with navigation
import ThemeToggle from '../components/ThemeToggle';

// Get current page path
const currentPage = Astro.url.pathname;

// Helper function to check if link is active
function isActive(path: string): boolean {
  return currentPage === path || currentPage === path + '/';
}

// Auth state (will be populated from cookies/localStorage in production)
const isAuthenticated = false;
const user = null;
---

<header class="sticky top-0 z-50 w-full border-b bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      <!-- Logo -->
      <div class="flex items-center">
        <a href="/" class="flex items-center space-x-2">
          <svg class="h-6 w-6 text-[#0d9488]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
          </svg>
          <span class="text-lg font-bold text-[#0d9488]">EduLaluan</span>
        </a>
      </div>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex md:items-center md:space-x-6">
        <a href="/" class={`text-sm font-medium transition-colors nav-link ${isActive('/') ? 'nav-link-active' : ''}`}>Home</a>
        <a href="/panduan-rakyat" class={`text-sm font-medium transition-colors nav-link ${currentPage.startsWith('/panduan-rakyat') ? 'nav-link-active' : ''}`}>People's Guide</a>
        <a href="/navigate" class={`text-sm font-medium transition-colors nav-link ${isActive('/navigate') ? 'nav-link-active' : ''}`}>Navigate</a>
        <a href="/resources" class={`text-sm font-medium transition-colors nav-link ${isActive('/resources') ? 'nav-link-active' : ''}`}>Resources</a>
        <a href="/contribute" class={`text-sm font-medium transition-colors nav-link ${isActive('/contribute') ? 'nav-link-active' : ''}`}>Contribute</a>
        <a href="/about" class={`text-sm font-medium transition-colors nav-link ${isActive('/about') ? 'nav-link-active' : ''}`}>About</a>
      </nav>

      <!-- Right side actions -->
      <div class="flex items-center gap-2">
        <!-- Auth Buttons (when not authenticated) -->
        <div id="auth-buttons" class="hidden md:flex items-center gap-2">
          <a
            href="/auth/login"
            class="text-sm font-medium text-foreground transition-colors hover:text-primary"
          >
            Sign In
          </a>
          <a
            href="/auth/signup"
            class="inline-flex items-center rounded-lg bg-primary px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-primary/90"
          >
            Sign Up
          </a>
        </div>

        <!-- User Menu (when authenticated) -->
        <div id="user-menu" class="hidden md:flex items-center gap-3">
          <a
            href="/user/dashboard"
            class="text-sm font-medium text-foreground transition-colors hover:text-primary"
          >
            Dashboard
          </a>
          <div class="relative group">
            <button class="flex items-center gap-2 rounded-full bg-primary/10 p-1 pr-3 transition-colors hover:bg-primary/20">
              <div class="rounded-full bg-primary p-1.5">
                <svg class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
              </div>
              <span class="text-sm font-medium text-foreground">My Account</span>
              <svg class="h-4 w-4 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <!-- Dropdown -->
            <div class="absolute right-0 mt-2 w-48 rounded-lg border bg-surface-elevated py-1 shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all">
              <a href="/user/dashboard" class="block px-4 py-2 text-sm text-foreground hover:bg-accent">Dashboard</a>
              <a href="/user/submissions" class="block px-4 py-2 text-sm text-foreground hover:bg-accent">My Submissions</a>
              <a href="/user/badges" class="block px-4 py-2 text-sm text-foreground hover:bg-accent">Badges</a>
              <div class="border-t my-1"></div>
              <button id="logout-btn" class="w-full text-left px-4 py-2 text-sm text-red-600 hover:bg-accent">Sign Out</button>
            </div>
          </div>
        </div>

        <!-- Theme Toggle -->
        <ThemeToggle client:load />

        <!-- Mobile menu button -->
        <button id="mobile-menu-button" class="md:hidden inline-flex items-center justify-center p-2 rounded-md text-foreground hover:bg-accent">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Navigation -->
    <div id="mobile-menu" class="hidden md:hidden pb-4">
      <div class="flex flex-col space-y-2">
        <a href="/" class={`text-sm font-medium transition-colors nav-link ${isActive('/') ? 'nav-link-active' : ''}`}>Home</a>
        <a href="/panduan-rakyat" class={`text-sm font-medium transition-colors nav-link ${currentPage.startsWith('/panduan-rakyat') ? 'nav-link-active' : ''}`}>People's Guide</a>
        <a href="/navigate" class={`text-sm font-medium transition-colors nav-link ${isActive('/navigate') ? 'nav-link-active' : ''}`}>Navigate</a>
        <a href="/resources" class={`text-sm font-medium transition-colors nav-link ${isActive('/resources') ? 'nav-link-active' : ''}`}>Resources</a>
        <a href="/contribute" class={`text-sm font-medium transition-colors nav-link ${isActive('/contribute') ? 'nav-link-active' : ''}`}>Contribute</a>
        <a href="/about" class={`text-sm font-medium transition-colors nav-link ${isActive('/about') ? 'nav-link-active' : ''}`}>About</a>
        <!-- Mobile Auth Buttons -->
        <div id="mobile-auth-buttons" class="hidden pt-2 space-y-2">
          <a
            href="/auth/login"
            class="block rounded-lg border border-input bg-background px-4 py-2 text-sm font-medium text-foreground transition-colors hover:bg-accent"
          >
            Sign In
          </a>
          <a
            href="/auth/signup"
            class="block rounded-lg bg-primary px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-primary/90 text-center"
          >
            Sign Up
          </a>
        </div>
        <!-- Mobile User Menu -->
        <div id="mobile-user-menu" class="hidden pt-2 space-y-2">
          <a
            href="/user/dashboard"
            class="block rounded-lg bg-primary/10 px-4 py-2 text-sm font-medium text-primary"
          >
            Dashboard
          </a>
          <a
            href="/user/submissions"
            class="block rounded-lg border border-input bg-background px-4 py-2 text-sm font-medium text-foreground transition-colors hover:bg-accent"
          >
            My Submissions
          </a>
          <a
            href="/user/badges"
            class="block rounded-lg border border-input bg-background px-4 py-2 text-sm font-medium text-foreground transition-colors hover:bg-accent"
          >
            Badges
          </a>
          <button
            id="mobile-logout-btn"
            class="w-full rounded-lg border border-red-200 bg-red-50 px-4 py-2 text-sm font-medium text-red-600 transition-colors hover:bg-red-100"
          >
            Sign Out
          </button>
        </div>
        <!-- Mobile Theme Toggle -->
        <div class="pt-2">
          <ThemeToggle client:load />
        </div>
      </div>
    </div>
  </div>
</header>

<style>
  .nav-link {
    color: var(--foreground);
    padding-bottom: 4px;
  }

  .nav-link:hover {
    color: var(--primary);
  }

  .nav-link-active {
    color: var(--primary);
    position: relative;
  }

  .nav-link-active::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
    background-color: var(--primary);
    border-radius: 2px;
  }
</style>

<script>
  // Mobile menu toggle
  const button = document.getElementById('mobile-menu-button');
  const menu = document.getElementById('mobile-menu');

  button?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  // Auth state management
  function checkAuthState() {
    const session = localStorage.getItem('edulaluan_session');
    const user = localStorage.getItem('edulaluan_user');
    const isAuthenticated = !!session && !!user;

    const authButtons = document.getElementById('auth-buttons');
    const userMenu = document.getElementById('user-menu');
    const mobileAuthButtons = document.getElementById('mobile-auth-buttons');
    const mobileUserMenu = document.getElementById('mobile-user-menu');

    if (isAuthenticated) {
      // Show user menu
      authButtons?.classList.add('hidden');
      userMenu?.classList.remove('hidden');
      mobileAuthButtons?.classList.add('hidden');
      mobileUserMenu?.classList.remove('hidden');
    } else {
      // Show auth buttons
      authButtons?.classList.remove('hidden');
      userMenu?.classList.add('hidden');
      mobileAuthButtons?.classList.remove('hidden');
      mobileUserMenu?.classList.add('hidden');
    }
  }

  // Check auth state on load
  checkAuthState();

  // Logout handler
  document.getElementById('logout-btn')?.addEventListener('click', () => {
    localStorage.removeItem('edulaluan_session');
    localStorage.removeItem('edulaluan_user');
    window.location.href = '/';
  });

  document.getElementById('mobile-logout-btn')?.addEventListener('click', () => {
    localStorage.removeItem('edulaluan_session');
    localStorage.removeItem('edulaluan_user');
    window.location.href = '/';
  });

  // Listen for storage changes (logout from other tabs)
  window.addEventListener('storage', checkAuthState);
</script>
