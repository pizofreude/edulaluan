---
// Admin Sidebar Component
interface Props {
  current: string;
}

const { current = 'dashboard' } = Astro.props;

const navItems = [
  { href: '/admin/dashboard', label: 'Dashboard', icon: 'dashboard', key: 'dashboard' },
  { href: '/admin/moderation', label: 'Moderation', icon: 'moderation', key: 'moderation' },
  { href: '/admin/manage', label: 'Manage Admins', icon: 'manage', key: 'manage' },
  { href: '/admin/users', label: 'Users', icon: 'users', key: 'users' },
  { href: '/admin/settings', label: 'Settings', icon: 'settings', key: 'settings' },
];

function getIcon(name: string) {
  const icons: Record<string, any> = {
    dashboard: `<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
      </svg>`,
    moderation: `<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
      </svg>`,
    manage: `<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
      </svg>`,
    users: `<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
      </svg>`,
    settings: `<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
      </svg>`,
  };
  return icons[name] || icons.dashboard;
}
---

<aside class="w-64 border-r bg-surface-elevated min-h-screen flex flex-col">
  <!-- Admin Header -->
  <div class="border-b p-5">
    <div class="flex items-center gap-2.5">
      <div class="rounded-md p-2" style="background-color: #D1FAE5;">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #059669;">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
      </div>
      <div class="leading-tight">
        <h3 class="text-sm font-semibold tracking-tight" style="color: #111827;">Admin</h3>
        <p class="text-xs font-medium" style="color: #6B7280;">Platform Management</p>
      </div>
    </div>
  </div>

  <!-- Navigation -->
  <nav class="p-3 space-y-0.5">
    <div class="px-3 py-2 text-xs font-semibold uppercase tracking-wider" style="color: #6B7280;">
      Menu
    </div>
    {navItems.map((item) => (
      <a
        href={item.href}
        class={`flex items-center gap-3 rounded-md px-3 py-2 text-sm font-medium transition-all ${
          current === item.key
            ? ''
            : 'hover:bg-gray-100'
        }`}
        style={current === item.key 
          ? 'background-color: #059669; color: white;' 
          : 'color: #374151;'
        }
        onmouseover={current !== item.key ? "this.style.backgroundColor='#F3F4F6'" : undefined}
        onmouseout={current !== item.key ? "this.style.backgroundColor='transparent'" : undefined}
      >
        <span set:html={getIcon(item.icon)} style={current === item.key ? 'color: white;' : 'color: #374151;'} />
        {item.label}
      </a>
    ))}
  </nav>

  <!-- Back to Site -->
  <div class="mt-auto border-t p-3" style="border-color: #E5E7EB;">
    <a
      href="/"
      class="flex items-center gap-3 rounded-md px-3 py-2 text-sm font-medium transition-all hover:bg-gray-100"
      style="color: #6B7280;"
    >
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: #6B7280;">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
      </svg>
      <span>Back to Site</span>
    </a>
  </div>
</aside>
