---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Button } from '../components/ui/button';
---

<Layout title="Contribute to EduLaluan">
  <Header />

  <main class="min-h-screen bg-background">
    <div class="container mx-auto px-4 py-12 max-w-4xl">
      <!-- Hero Section -->
      <div class="text-center mb-12">
        <h1 class="font-display text-4xl font-bold text-foreground mb-4">
          🤝 Contribute to EduLaluan
        </h1>
        <p class="text-xl text-muted-foreground mb-6">
          Help us grow Malaysia's education resource database!
        </p>
        <p class="text-muted-foreground">
          Your contributions help Malaysian families discover educational opportunities.
          No GitHub account needed - just fill out a simple form.
        </p>
      </div>

      <!-- Contribution Options -->
      <div class="grid gap-6 md:grid-cols-1 max-w-2xl mx-auto">

        <!-- Submit Education Resource -->
        <div class="bg-surface border-2 border-primary/20 rounded-lg p-6 hover:border-primary/40 transition-colors">
          <div class="flex items-start gap-4">
            <div class="text-4xl">📚</div>
            <div class="flex-1">
              <h2 class="font-display text-2xl font-semibold text-foreground mb-2">
                Submit Education Resource
              </h2>
              <p class="text-muted-foreground mb-4">
                Share scholarships, free courses, training programs, schools, or any educational opportunity
                that can help Malaysian students and families.
              </p>
              <a href="/contribute/resource" class="inline-block">
                <Button className="bg-primary hover:bg-primary-dark text-primary-foreground">
                  Submit Resource →
                </Button>
              </a>
            </div>
          </div>
        </div>

        <!-- Submit Financial Aid -->
        <div class="bg-surface border-2 border-accent/20 rounded-lg p-6 hover:border-accent/40 transition-colors">
          <div class="flex items-start gap-4">
            <div class="text-4xl">💰</div>
            <div class="flex-1">
              <h2 class="font-display text-2xl font-semibold text-foreground mb-2">
                Submit Financial Aid Program
              </h2>
              <p class="text-muted-foreground mb-4">
                Offering scholarships, grants, bursaries, or sponsorships? Share your financial aid
                program to help students access education. Open to organizations and individuals.
              </p>
              <a href="/contribute/financial-aid" class="inline-block">
                <Button className="bg-accent hover:bg-accent-light text-foreground">
                  Submit Financial Aid →
                </Button>
              </a>
            </div>
          </div>
        </div>

        <!-- Request Feature -->
        <div class="bg-surface border-2 border-border rounded-lg p-6 hover:border-muted-foreground transition-colors">
          <div class="flex items-start gap-4">
            <div class="text-4xl">💡</div>
            <div class="flex-1">
              <h2 class="font-display text-2xl font-semibold text-foreground mb-2">
                Request a Feature
              </h2>
              <p class="text-muted-foreground mb-4">
                Have ideas to improve EduLaluan? Suggest new features, improvements,
                or report issues to help us serve the community better.
              </p>
              <a href="/contribute/feature-request" class="inline-block">
                <Button variant="outline" className="border-border hover:bg-muted">
                  Request Feature →
                </Button>
              </a>
            </div>
          </div>
        </div>

      </div>

      <!-- Already have GitHub -->
      <div class="mt-12 text-center p-6 bg-surface rounded-lg">
        <p class="text-muted-foreground mb-3">
          <strong>Already familiar with GitHub?</strong>
        </p>
        <p class="text-muted-foreground">
          You can contribute directly via pull requests:
          <a
            href="https://github.com/pizofreude/edulaluan"
            target="_blank"
            rel="noopener noreferrer"
            class="text-primary-light hover:text-primary underline ml-1"
          >
            GitHub Repository →
          </a>
        </p>
      </div>

      <!-- What Happens Next -->
      <div class="mt-12 bg-muted/50 border border-border rounded-lg p-6">
        <h3 class="font-display text-lg font-semibold text-foreground mb-3">
          📋 What happens after you submit?
        </h3>
        <ol class="space-y-2 text-foreground">
          <li class="flex items-start gap-2">
            <span class="font-semibold">1.</span>
            <span>Your submission is received and validated</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="font-semibold">2.</span>
            <span>Our team reviews it for accuracy and quality (typically 2-3 days)</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="font-semibold">3.</span>
            <span>Once approved, it goes live on the website</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="font-semibold">4.</span>
            <span>You'll receive an email confirmation when it's published</span>
          </li>
        </ol>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
