---
// User Settings Page
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import UserSidebar from '../../components/user/UserSidebar.astro';

const currentPage = 'settings';
---

<Layout title="Settings | EduLaluan">
  <Header />

  <div class="flex min-h-screen">
    <!-- User Sidebar -->
    <UserSidebar current={currentPage} />

    <!-- Main Content -->
    <main class="flex-1 ml-64 bg-surface p-8 transition-all duration-300" id="main-content">
      <!-- Page Header -->
      <div class="mb-8">
        <h1 class="text-3xl font-bold text-foreground">Settings</h1>
        <p class="mt-2 text-base text-foreground/80">
          Manage your account settings and preferences
        </p>
      </div>

      <!-- Settings Sections -->
      <div class="space-y-6">
        <!-- Profile Section -->
        <div class="rounded-xl border bg-surface-elevated p-6 shadow-sm">
          <h2 class="text-xl font-semibold text-foreground mb-4">Profile Information</h2>
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-semibold text-foreground mb-1">Full Name</label>
              <input
                type="text"
                id="fullName"
                class="w-full rounded-md border border-input bg-background px-4 py-2 text-sm font-medium text-foreground focus:outline-none focus:ring-2 focus:ring-primary"
                placeholder="Your full name"
              />
            </div>
            <div>
              <label class="block text-sm font-semibold text-foreground mb-1">Email</label>
              <input
                type="email"
                id="email"
                class="w-full rounded-md border border-input bg-background px-4 py-2 text-sm font-medium text-foreground focus:outline-none focus:ring-2 focus:ring-primary"
                placeholder="your@email.com"
              />
            </div>
            <div>
              <label class="block text-sm font-semibold text-foreground mb-1">Bio</label>
              <textarea
                id="bio"
                rows="3"
                class="w-full rounded-md border border-input bg-background px-4 py-2 text-sm font-medium text-foreground focus:outline-none focus:ring-2 focus:ring-primary"
                placeholder="Tell us about yourself..."
              ></textarea>
            </div>
            <button
              id="save-profile-btn"
              style="background-color: #0f766e; color: white;"
              class="inline-flex items-center gap-2 rounded-lg px-4 py-2.5 text-sm font-semibold shadow-md transition-all hover:shadow-lg"
            >
              Save Changes
            </button>
            <p id="profile-message" class="text-sm hidden"></p>
          </div>
        </div>

        <!-- Username Section -->
        <div class="rounded-xl border bg-surface-elevated p-6 shadow-sm">
          <h2 class="text-xl font-semibold text-foreground mb-4">Username</h2>
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-foreground mb-1">
                Public Username
              </label>
              <div class="flex items-center gap-3">
                <div class="relative flex-1">
                  <input
                    type="text"
                    id="username"
                    class="w-full px-3 py-2 border border-border rounded-md bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-primary pr-20"
                    placeholder="Not set"
                    minlength="3"
                    maxlength="30"
                    pattern="^[a-zA-Z][a-zA-Z0-9_]*$"
                  />
                  <span id="username-status" class="absolute right-3 top-2 text-sm"></span>
                </div>
                <button
                  id="save-username-btn"
                  style="background-color: #059669; color: white;"
                  class="px-4 py-2 rounded-md font-semibold hover:bg-emerald-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
                >
                  Save
                </button>
              </div>
              <p class="text-xs text-muted-foreground mt-2">
                Your username will be shown on leaderboards and public contributions instead of your real name.
              </p>
              <div class="mt-2 text-xs text-muted-foreground space-y-1">
                <p>• 3-30 characters</p>
                <p>• Letters, numbers, and underscores only</p>
                <p>• Must start with a letter</p>
                <p>• Can be changed once every 90 days</p>
              </div>
              <div id="username-suggestions" class="mt-3 hidden">
                <p class="text-xs font-medium text-muted-foreground mb-2">Suggestions:</p>
                <div class="flex flex-wrap gap-2" id="username-suggestions-list"></div>
              </div>
              <p id="username-message" class="text-sm mt-2 hidden"></p>
            </div>
          </div>
        </div>

        <!-- Change Password Section -->
        <div class="rounded-xl border bg-surface-elevated p-6 shadow-sm">
          <h2 class="text-xl font-semibold text-foreground mb-4">Change Password</h2>
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-semibold text-foreground mb-1">Current Password</label>
              <input
                type="password"
                id="currentPassword"
                class="w-full rounded-md border border-input bg-background px-4 py-2 text-sm font-medium text-foreground focus:outline-none focus:ring-2 focus:ring-primary"
                placeholder="Enter current password"
              />
            </div>
            <div>
              <label class="block text-sm font-semibold text-foreground mb-1">New Password</label>
              <input
                type="password"
                id="newPassword"
                class="w-full rounded-md border border-input bg-background px-4 py-2 text-sm font-medium text-foreground focus:outline-none focus:ring-2 focus:ring-primary"
                placeholder="Enter new password"
              />
            </div>
            <div>
              <label class="block text-sm font-semibold text-foreground mb-1">Confirm New Password</label>
              <input
                type="password"
                id="confirmPassword"
                class="w-full rounded-md border border-input bg-background px-4 py-2 text-sm font-medium text-foreground focus:outline-none focus:ring-2 focus:ring-primary"
                placeholder="Confirm new password"
              />
            </div>
            <button
              id="update-password-btn"
              style="background-color: #0f766e; color: white;"
              class="inline-flex items-center gap-2 rounded-lg px-4 py-2.5 text-sm font-semibold shadow-md transition-all hover:shadow-lg"
            >
              Update Password
            </button>
            <p id="password-message" class="text-sm hidden"></p>
          </div>
        </div>

        <!-- Notification Preferences -->
        <div class="rounded-xl border bg-surface-elevated p-6 shadow-sm">
          <h2 class="text-xl font-semibold text-foreground mb-4">Notification Preferences</h2>
          <div class="space-y-4">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm font-semibold text-foreground">Email Notifications</p>
                <p class="text-xs text-foreground/60">Receive emails about your submissions</p>
              </div>
              <label class="relative inline-flex items-center cursor-pointer">
                <input type="checkbox" id="email-notifications" class="sr-only peer" />
                <div class="w-12 h-7 bg-gray-300 dark:bg-gray-700 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-primary rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[3px] after:left-[4px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-teal-600 dark:peer-checked:bg-teal-500"></div>
              </label>
            </div>
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm font-semibold text-foreground">Approval Notifications</p>
                <p class="text-xs text-foreground/60">Get notified when submissions are approved</p>
              </div>
              <label class="relative inline-flex items-center cursor-pointer">
                <input type="checkbox" id="approval-notifications" class="sr-only peer" />
                <div class="w-12 h-7 bg-gray-300 dark:bg-gray-700 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-primary rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[3px] after:left-[4px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-teal-600 dark:peer-checked:bg-teal-500"></div>
              </label>
            </div>
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm font-semibold text-foreground">Weekly Digest</p>
                <p class="text-xs text-foreground/60">Receive weekly summary of platform activity</p>
              </div>
              <label class="relative inline-flex items-center cursor-pointer">
                <input type="checkbox" id="weekly-digest" class="sr-only peer" />
                <div class="w-12 h-7 bg-gray-300 dark:bg-gray-700 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-primary rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[3px] after:left-[4px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-teal-600 dark:peer-checked:bg-teal-500"></div>
              </label>
            </div>
            <button
              id="save-notifications-btn"
              style="background-color: #0f766e; color: white;"
              class="inline-flex items-center gap-2 rounded-lg px-4 py-2.5 text-sm font-semibold shadow-md transition-all hover:shadow-lg mt-4"
            >
              Save Preferences
            </button>
            <p id="notifications-message" class="text-sm hidden"></p>
          </div>
        </div>

        <!-- Danger Zone -->
        <div class="rounded-xl border border-red-200 bg-red-50 p-6 dark:border-red-800 dark:bg-red-900/20">
          <h2 class="text-xl font-semibold text-red-700 dark:text-red-400 mb-4">Danger Zone</h2>
          <div class="space-y-4">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm font-semibold text-red-700 dark:text-red-400">Delete Account</p>
                <p class="text-xs text-red-600/80 dark:text-red-500/80">Permanently delete your account and all data</p>
              </div>
              <button
                id="delete-account-btn"
                style="background-color: #b91c1c; color: white;"
                class="inline-flex items-center gap-2 rounded-lg px-4 py-2.5 text-sm font-semibold shadow-md transition-all hover:shadow-lg"
              >
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                </svg>
                Delete Account
              </button>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>

  <Footer />
</Layout>

<script>
  // Load user data from Supabase auth
  async function loadUserData() {
    try {
      const { createClient } = await import('@supabase/supabase-js');
      const supabase = createClient(
        import.meta.env.PUBLIC_SUPABASE_URL,
        import.meta.env.PUBLIC_SUPABASE_PUBLISHABLE_KEY || import.meta.env.PUBLIC_SUPABASE_PUBLISHABLE_KEY
      );

      const { data: { user }, error } = await supabase.auth.getUser();

      if (error || !user) {
        console.error('[Settings] Failed to load user data:', error);
        return;
      }

      // Prefill form with user data
      const emailInput = document.getElementById('email') as HTMLInputElement;
      const fullNameInput = document.getElementById('fullName') as HTMLInputElement;
      const bioInput = document.getElementById('bio') as HTMLTextAreaElement;

      if (emailInput) emailInput.value = user.email || '';
      if (fullNameInput) fullNameInput.value = user.user_metadata?.full_name || user.email?.split('@')[0] || 'User';
      if (bioInput) bioInput.value = user.user_metadata?.bio || '';

      // Load notification preferences
      const emailNotif = document.getElementById('email-notifications') as HTMLInputElement;
      const approvalNotif = document.getElementById('approval-notifications') as HTMLInputElement;
      const weeklyDigest = document.getElementById('weekly-digest') as HTMLInputElement;

      if (emailNotif) emailNotif.checked = user.user_metadata?.email_notifications !== false;
      if (approvalNotif) approvalNotif.checked = user.user_metadata?.approval_notifications !== false;
      if (weeklyDigest) weeklyDigest.checked = user.user_metadata?.weekly_digest === true;

      console.log('[Settings] User data loaded:', user.email);
    } catch (error) {
      console.error('[Settings] Error loading user data:', error);
    }
  }

  // Load user data on page load
  loadUserData();

  // Save profile handler
  document.getElementById('save-profile-btn')?.addEventListener('click', async () => {
    const messageEl = document.getElementById('profile-message');
    const fullName = (document.getElementById('fullName') as HTMLInputElement)?.value;
    const email = (document.getElementById('email') as HTMLInputElement)?.value;
    const bio = (document.getElementById('bio') as HTMLTextAreaElement)?.value;

    if (!messageEl) return;

    try {
      const { createClient } = await import('@supabase/supabase-js');
      const supabase = createClient(
        import.meta.env.PUBLIC_SUPABASE_URL,
        import.meta.env.PUBLIC_SUPABASE_PUBLISHABLE_KEY || import.meta.env.PUBLIC_SUPABASE_PUBLISHABLE_KEY
      );

      const { error } = await supabase.auth.updateUser({
        email,
        data: { full_name: fullName, bio }
      });

      if (error) throw error;

      messageEl.textContent = 'Profile updated successfully!';
      messageEl.className = 'text-sm text-green-600 dark:text-green-400';
      messageEl.classList.remove('hidden');
    } catch (error: any) {
      messageEl.textContent = error.message || 'Failed to update profile';
      messageEl.className = 'text-sm text-red-600 dark:text-red-400';
      messageEl.classList.remove('hidden');
    }

    setTimeout(() => messageEl.classList.add('hidden'), 3000);
  });

  // Update password handler
  document.getElementById('update-password-btn')?.addEventListener('click', async () => {
    const messageEl = document.getElementById('password-message');
    const currentPassword = (document.getElementById('currentPassword') as HTMLInputElement)?.value;
    const newPassword = (document.getElementById('newPassword') as HTMLInputElement)?.value;
    const confirmPassword = (document.getElementById('confirmPassword') as HTMLInputElement)?.value;

    if (!messageEl) return;

    // Validation
    if (!currentPassword || !newPassword || !confirmPassword) {
      messageEl.textContent = 'Please fill in all fields';
      messageEl.className = 'text-sm text-red-600 dark:text-red-400';
      messageEl.classList.remove('hidden');
      return;
    }

    if (newPassword !== confirmPassword) {
      messageEl.textContent = 'New passwords do not match';
      messageEl.className = 'text-sm text-red-600 dark:text-red-400';
      messageEl.classList.remove('hidden');
      return;
    }

    if (newPassword.length < 8) {
      messageEl.textContent = 'Password must be at least 8 characters';
      messageEl.className = 'text-sm text-red-600 dark:text-red-400';
      messageEl.classList.remove('hidden');
      return;
    }

    try {
      const { createClient } = await import('@supabase/supabase-js');
      const supabase = createClient(
        import.meta.env.PUBLIC_SUPABASE_URL,
        import.meta.env.PUBLIC_SUPABASE_PUBLISHABLE_KEY || import.meta.env.PUBLIC_SUPABASE_PUBLISHABLE_KEY
      );

      // First verify current password by signing in
      const { data: signInData, error: signInError } = await supabase.auth.signInWithPassword({
        email: (document.getElementById('email') as HTMLInputElement)?.value || '',
        password: currentPassword
      });

      if (signInError || !signInData.user) {
        throw new Error('Current password is incorrect');
      }

      // Update password
      const { error } = await supabase.auth.updateUser({
        password: newPassword
      });

      if (error) throw error;

      messageEl.textContent = 'Password updated successfully!';
      messageEl.className = 'text-sm text-green-600 dark:text-green-400';
      messageEl.classList.remove('hidden');

      // Clear password fields
      (document.getElementById('currentPassword') as HTMLInputElement).value = '';
      (document.getElementById('newPassword') as HTMLInputElement).value = '';
      (document.getElementById('confirmPassword') as HTMLInputElement).value = '';
    } catch (error: any) {
      messageEl.textContent = error.message || 'Failed to update password';
      messageEl.className = 'text-sm text-red-600 dark:text-red-400';
      messageEl.classList.remove('hidden');
    }

    setTimeout(() => messageEl.classList.add('hidden'), 3000);
  });

  // Save notification preferences handler
  document.getElementById('save-notifications-btn')?.addEventListener('click', async () => {
    const messageEl = document.getElementById('notifications-message');
    
    const emailNotifications = (document.getElementById('email-notifications') as HTMLInputElement)?.checked;
    const approvalNotifications = (document.getElementById('approval-notifications') as HTMLInputElement)?.checked;
    const weeklyDigest = (document.getElementById('weekly-digest') as HTMLInputElement)?.checked;

    if (!messageEl) return;

    try {
      const { createClient } = await import('@supabase/supabase-js');
      const supabase = createClient(
        import.meta.env.PUBLIC_SUPABASE_URL,
        import.meta.env.PUBLIC_SUPABASE_PUBLISHABLE_KEY || import.meta.env.PUBLIC_SUPABASE_PUBLISHABLE_KEY
      );

      const { error } = await supabase.auth.updateUser({
        data: {
          email_notifications: emailNotifications,
          approval_notifications: approvalNotifications,
          weekly_digest: weeklyDigest
        }
      });

      if (error) throw error;

      messageEl.textContent = 'Notification preferences saved!';
      messageEl.className = 'text-sm text-green-600 dark:text-green-400';
      messageEl.classList.remove('hidden');
    } catch (error: any) {
      messageEl.textContent = error.message || 'Failed to save preferences';
      messageEl.className = 'text-sm text-red-600 dark:text-red-400';
      messageEl.classList.remove('hidden');
    }

    setTimeout(() => messageEl.classList.add('hidden'), 3000);
  });

  // Delete account handler
  document.getElementById('delete-account-btn')?.addEventListener('click', async () => {
    const confirmed = confirm('Are you sure you want to delete your account? This action cannot be undone.');
    if (!confirmed) return;

    const secondConfirm = confirm('WARNING: This will permanently delete your account and all data. This cannot be undone.');
    if (!secondConfirm) return;

    try {
      const { createClient } = await import('@supabase/supabase-js');
      const supabase = createClient(
        import.meta.env.PUBLIC_SUPABASE_URL,
        import.meta.env.PUBLIC_SUPABASE_PUBLISHABLE_KEY || import.meta.env.PUBLIC_SUPABASE_PUBLISHABLE_KEY
      );

      // Get current session
      const { data: { session } } = await supabase.auth.getSession();
      
      if (!session || !session.access_token) {
        alert('Please sign in again before deleting your account');
        window.location.href = '/auth/login';
        return;
      }

      // Call our API endpoint that uses service role key
      const response = await fetch('/api/user/delete-account', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${session.access_token}`
        }
      });

      const result = await response.json();

      if (!response.ok) {
        throw new Error(result.error || 'Failed to delete account');
      }

      alert('Account deleted successfully');
      window.location.href = '/';
    } catch (error: any) {
      alert(error.message || 'Failed to delete account');
    }
  });

  // ==========================================
  // Username Management
  // ==========================================

  let usernameCheckTimeout: number;

  // Load current username on page load
  async function loadUsername() {
    try {
      const { createClient } = await import('@supabase/supabase-js');
      const supabase = createClient(
        import.meta.env.PUBLIC_SUPABASE_URL,
        import.meta.env.PUBLIC_SUPABASE_PUBLISHABLE_KEY
      );

      const { data: { session } } = await supabase.auth.getSession();

      if (!session?.access_token) return;

      // Get user data from users table
      const { data: userData } = await supabase
        .from('users')
        .select('username, username_updated_at')
        .eq('id', session.user.id)
        .single();

      if (userData) {
        const usernameInput = document.getElementById('username') as HTMLInputElement;
        const usernameStatus = document.getElementById('username-status');
        
        if (usernameInput) {
          usernameInput.value = userData.username || '';
          usernameInput.placeholder = userData.username ? userData.username : 'Not set';
        }

        if (usernameStatus && userData.username) {
          usernameStatus.textContent = '✓ Set';
          usernameStatus.className = 'absolute right-3 top-2 text-sm text-green-600';
        }
      }
    } catch (error) {
      console.error('[Username] Failed to load username:', error);
    }
  }

  // Load username on page load
  loadUsername();

  // Real-time username availability check
  document.getElementById('username')?.addEventListener('input', async (e) => {
    const username = (e.target as HTMLInputElement).value.trim();
    const usernameStatus = document.getElementById('username-status');
    const suggestionsDiv = document.getElementById('username-suggestions');
    const suggestionsList = document.getElementById('username-suggestions-list');

    // Clear previous timeout
    clearTimeout(usernameCheckTimeout);

    if (username.length < 3) {
      if (usernameStatus) {
        usernameStatus.textContent = '';
        suggestionsDiv?.classList.add('hidden');
      }
      return;
    }

    // Debounce check
    usernameCheckTimeout = setTimeout(async () => {
      if (usernameStatus) {
        usernameStatus.textContent = 'Checking...';
        usernameStatus.className = 'absolute right-3 top-2 text-sm text-muted-foreground';
      }

      try {
        const response = await fetch('/api/user/check-username', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ username })
        });

        const result = await response.json();

        if (result.available) {
          if (usernameStatus) {
            usernameStatus.textContent = '✓ Available';
            usernameStatus.className = 'absolute right-3 top-2 text-sm text-green-600';
          }
          suggestionsDiv?.classList.add('hidden');
        } else {
          if (usernameStatus) {
            usernameStatus.textContent = '✗ Taken';
            usernameStatus.className = 'absolute right-3 top-2 text-sm text-red-600';
          }

          // Show suggestions
          if (result.suggestions && result.suggestions.length > 0) {
            suggestionsList!.innerHTML = result.suggestions
              .map(s => `<button type="button" class="username-suggestion px-3 py-1 text-sm bg-surface hover:bg-surface-elevated border rounded-full transition-colors">@${s}</button>`)
              .join('');
            suggestionsDiv?.classList.remove('hidden');

            // Add click handlers to suggestions
            suggestionsList?.querySelectorAll('.username-suggestion').forEach(btn => {
              btn.addEventListener('click', () => {
                const usernameInput = document.getElementById('username') as HTMLInputElement;
                if (usernameInput) usernameInput.value = btn.textContent?.replace('@', '') || '';
              });
            });
          }
        }
      } catch (error) {
        console.error('[Username] Check failed:', error);
      }
    }, 500);
  });

  // Save username handler
  document.getElementById('save-username-btn')?.addEventListener('click', async () => {
    const messageEl = document.getElementById('username-message');
    const usernameInput = document.getElementById('username') as HTMLInputElement;
    const username = usernameInput?.value.trim();

    if (!messageEl || !usernameInput) return;

    if (!username) {
      messageEl.textContent = 'Please enter a username';
      messageEl.className = 'text-sm text-red-600';
      messageEl.classList.remove('hidden');
      return;
    }

    if (username.length < 3) {
      messageEl.textContent = 'Username must be at least 3 characters';
      messageEl.className = 'text-sm text-red-600';
      messageEl.classList.remove('hidden');
      return;
    }

    try {
      messageEl.textContent = 'Saving...';
      messageEl.className = 'text-sm text-muted-foreground';
      messageEl.classList.remove('hidden');

      const { createClient } = await import('@supabase/supabase-js');
      const supabase = createClient(
        import.meta.env.PUBLIC_SUPABASE_URL,
        import.meta.env.PUBLIC_SUPABASE_PUBLISHABLE_KEY
      );

      const { data: { session } } = await supabase.auth.getSession();

      if (!session?.access_token) {
        throw new Error('Authentication required. Please log in again.');
      }

      const response = await fetch('/api/user/set-username', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${session.access_token}`
        },
        body: JSON.stringify({ username })
      });

      const result = await response.json();

      if (!response.ok) {
        if (result.cooldown) {
          messageEl.textContent = `You can only change your username once every 90 days. ${result.daysRemaining} days remaining.`;
          messageEl.className = 'text-sm text-amber-600';
        } else {
          messageEl.textContent = result.error || 'Failed to save username';
          messageEl.className = 'text-sm text-red-600';
        }
        return;
      }

      messageEl.textContent = 'Username saved successfully!';
      messageEl.className = 'text-sm text-green-600';
      
      // Update status indicator
      const usernameStatus = document.getElementById('username-status');
      if (usernameStatus) {
        usernameStatus.textContent = '✓ Set';
        usernameStatus.className = 'absolute right-3 top-2 text-sm text-green-600';
      }

      // Hide suggestions
      document.getElementById('username-suggestions')?.classList.add('hidden');
    } catch (error: any) {
      messageEl.textContent = error.message || 'Failed to save username';
      messageEl.className = 'text-sm text-red-600';
    }

    setTimeout(() => messageEl.classList.add('hidden'), 5000);
  });
</script>
