---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';

// Fetch resources from Supabase API
const baseUrl = import.meta.env.PUBLIC_SUPABASE_URL || '';
const anonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY || '';

let featuredResources: any[] = [];
let totalResources: number | string = 138;

try {
  const response = await fetch(`${baseUrl}/rest/v1/resources?select=*,category:categories(slug,name),cost_type:cost_types(slug,name),mode:delivery_modes(slug,name),income_groups:resource_income_groups(income_groups:income_groups(slug,name)),tags:resource_tags(tags:tags(slug,name))&is_featured=eq.true&limit=6`, {
    headers: {
      'apikey': anonKey,
      'Authorization': `Bearer ${anonKey}`,
      'Prefer': 'count=exact'
    }
  });
  
  if (response.ok) {
    const data = await response.json();
    featuredResources = data || [];
    const count = response.headers.get('content-range')?.split('/')?.[1];
    if (count) {
      totalResources = parseInt(count, 10);
    }
  }
} catch (error) {
  console.error('Failed to fetch featured resources:', error);
  // Fallback: show empty state
}

const categoryCount = 10; // Fixed count for now
---

<Layout title="EduLaluan - Smart Education Resource Navigator">
  <Header />
  
  <main>
    <Hero />
    
    <!-- Stats Section - Redesigned with Malaysian Education Context -->
    <section class="relative py-section-md bg-surface overflow-hidden">
      <!-- Decorative batik pattern background -->
      <div class="absolute inset-0 opacity-[0.02] bg-batik-diamond" aria-hidden="true"></div>
      
      <div class="container relative mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Section header with distinctive typography -->
        <div class="text-center mb-12 animate-fade-in">
          <p class="text-sm font-medium text-primary mb-2 tracking-wide uppercase">Making Education Accessible</p>
          <h2 class="font-display text-3xl md:text-4xl font-bold mb-4">
            Empowering <span class="text-primary">138+</span> Educational Opportunities
          </h2>
          <p class="text-muted-foreground max-w-2xl mx-auto text-base md:text-lg">
            From B40 to T20, we connect Malaysian families with scholarships, courses, and resources that match their needs.
          </p>
        </div>

        <!-- Stats grid with visual hierarchy -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 mb-12">
          <!-- Stat 1: Resources -->
          <div class="group relative bg-surface-elevated rounded-2xl p-8 shadow-sm hover:shadow-xl transition-all duration-300 border border-border animate-fade-in-up">
            <div class="absolute top-0 right-0 w-20 h-20 opacity-5 text-primary" aria-hidden="true">
              <svg viewBox="0 0 100 100" fill="currentColor">
                <circle cx="50" cy="50" r="40" />
              </svg>
            </div>
            <div class="relative">
              <div class="text-5xl md:text-6xl font-display font-bold text-primary mb-2 tracking-tight">
                {totalResources || '138'}+
              </div>
              <div class="text-foreground font-medium mb-3">Educational Resources</div>
              <div class="text-sm text-muted-foreground leading-relaxed">
                Scholarships, MOOCs, TVET programs, and more — all verified and updated.
              </div>
              <!-- Decorative divider -->
              <div class="mt-4 pt-4 border-t border-border/50">
                <div class="flex items-center gap-2 text-xs text-primary font-medium">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                  </svg>
                  <span>Continuously Growing</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Stat 2: Categories -->
          <div class="group relative bg-surface-elevated rounded-2xl p-8 shadow-sm hover:shadow-xl transition-all duration-300 border border-border animate-fade-in-up" style="animation-delay: 100ms;">
            <div class="absolute top-0 right-0 w-20 h-20 opacity-5 text-accent" aria-hidden="true">
              <svg viewBox="0 0 100 100" fill="currentColor">
                <rect x="20" y="20" width="60" height="60" rx="8" />
              </svg>
            </div>
            <div class="relative">
              <div class="text-5xl md:text-6xl font-display font-bold text-accent mb-2 tracking-tight">
                {categoryCount}
              </div>
              <div class="text-foreground font-medium mb-3">Resource Categories</div>
              <div class="text-sm text-muted-foreground leading-relaxed">
                From scholarships to elite institutions, find resources for every educational path.
              </div>
              <!-- Decorative divider -->
              <div class="mt-4 pt-4 border-t border-border/50">
                <div class="flex items-center gap-2 text-xs text-accent font-medium">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                    <path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z" />
                  </svg>
                  <span>Diverse Options</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Stat 3: Income Groups -->
          <div class="group relative bg-surface-elevated rounded-2xl p-8 shadow-sm hover:shadow-xl transition-all duration-300 border border-border animate-fade-in-up" style="animation-delay: 200ms;">
            <div class="absolute top-0 right-0 w-20 h-20 opacity-5 text-primary-light" aria-hidden="true">
              <svg viewBox="0 0 100 100" fill="currentColor">
                <path d="M50 10 L90 30 L90 70 L50 90 L10 70 L10 30 Z" />
              </svg>
            </div>
            <div class="relative">
              <div class="text-5xl md:text-6xl font-display font-bold text-primary-light mb-2 tracking-tight">
                3
              </div>
              <div class="text-foreground font-medium mb-3">Income Groups Served</div>
              <div class="text-sm text-muted-foreground leading-relaxed">
                B40, M40, and T20 — personalized recommendations for every Malaysian family.
              </div>
              <!-- Decorative divider -->
              <div class="mt-4 pt-4 border-t border-border/50">
                <div class="flex items-center gap-2 text-xs text-primary-light font-medium">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                    <path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z" />
                  </svg>
                  <span>Inclusive Access</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- CTA to navigator -->
        <div class="text-center animate-fade-in" style="animation-delay: 300ms;">
          <a href="/navigate" class="inline-flex items-center gap-2 text-primary font-medium hover:text-primary-dark transition-colors group">
            Find Your Personalized Resources
            <svg class="w-5 h-5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- How It Works -->
    <section class="py-16">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-bold mb-4">How It Works</h2>
          <p class="text-xl text-muted-foreground max-w-2xl mx-auto">
            Three simple steps to find the perfect educational resources for you
          </p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="text-center">
            <div class="w-16 h-16 bg-malaysia-teal text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">1</div>
            <h3 class="text-xl font-semibold mb-3">Select Your Income Group</h3>
            <p class="text-muted-foreground">Tell us your household income bracket (B40, M40, or T20) to get personalized recommendations.</p>
          </div>
          <div class="text-center">
            <div class="w-16 h-16 bg-malaysia-teal text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">2</div>
            <h3 class="text-xl font-semibold mb-3">Choose Your Goal</h3>
            <p class="text-muted-foreground">Select what you're looking for: scholarships, courses, skills training, or financial aid.</p>
          </div>
          <div class="text-center">
            <div class="w-16 h-16 bg-malaysia-teal text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">3</div>
            <h3 class="text-xl font-semibold mb-3">Discover Resources</h3>
            <p class="text-muted-foreground">Get a curated list of resources tailored to your needs with direct links to apply.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Featured Resources -->
    <section class="py-16 bg-slate-50">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-bold mb-4">Featured Resources</h2>
          <p class="text-xl text-muted-foreground">
            Popular and highly recommended educational opportunities
          </p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
          {featuredResources.length > 0 ? (
            featuredResources.map((resource: any) => (
              <div class="border rounded-lg p-6 bg-white hover:shadow-lg transition-shadow">
                <h3 class="text-lg font-semibold mb-2">{resource.name}</h3>
                <p class="text-sm text-muted-foreground mb-3">{resource.provider_name}</p>
                <p class="text-sm mb-4">{resource.description}</p>
                <div class="flex flex-wrap gap-2 mb-4">
                  <span class={`inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold ${
                    resource.cost_type?.slug === 'free' ? 'bg-green-100 text-green-800' :
                    resource.cost_type?.slug === 'subsidized' ? 'bg-blue-100 text-blue-800' :
                    'bg-amber-100 text-amber-800'
                  }`}>
                    {resource.cost_type?.name || 'Paid'}
                  </span>
                  {resource.income_groups?.map((ig: any) => (
                    <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold bg-slate-100 text-slate-800">
                      {ig.income_groups?.name}
                    </span>
                  ))}
                </div>
                <a
                  href={resource.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center text-sm font-medium text-malaysia-teal hover:text-malaysia-teal-700"
                >
                  Learn more
                  <svg class="ml-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </a>
              </div>
            ))
          ) : (
            <div class="col-span-full text-center py-12">
              <p class="text-muted-foreground">Featured resources loading...</p>
            </div>
          )}
        </div>
        
        <div class="text-center">
          <a 
            href="/resources"
            class="inline-flex items-center justify-center px-6 py-3 bg-malaysia-teal hover:bg-malaysia-teal-700 text-white font-semibold rounded-lg transition-colors"
          >
            View All Resources
          </a>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-16">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="bg-gradient-to-br from-malaysia-teal to-teal-700 rounded-2xl p-12 text-center text-white">
          <h2 class="text-3xl md:text-4xl font-bold mb-4">Ready to Start Your Journey?</h2>
          <p class="text-xl mb-8 text-teal-50">
            Let us help you find the perfect educational resources for your goals.
          </p>
          <a 
            href="/navigate"
            class="inline-flex items-center justify-center px-8 py-3 bg-malaysia-gold hover:bg-malaysia-gold-700 text-white font-semibold rounded-lg shadow-lg transition-colors"
          >
            Start Navigating Now
            <svg class="ml-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>
