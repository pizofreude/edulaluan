---
// Signup Page
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const features = [
  'Earn points for contributions',
  'Unlock badges and achievements',
  'Climb the leaderboard',
  'Submit resources and financial aid',
  'Track your submission history',
  'Get notified when content is approved',
];
---

<Layout title="Sign Up | EduLaluan">
  <Header />

  <main class="min-h-screen bg-surface">
    <div class="flex min-h-screen">
      <!-- Left Side - Form -->
      <div class="flex-1 flex items-center justify-center p-8">
        <div class="w-full max-w-md">
          <!-- Logo -->
          <div class="text-center mb-8">
            <a href="/" class="inline-flex items-center space-x-2">
              <svg class="h-8 w-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
              </svg>
              <span class="text-xl font-bold text-primary">EduLaluan</span>
            </a>
          </div>

          <!-- Signup Form -->
          <div class="rounded-xl border bg-surface-elevated p-8 shadow-sm">
            <div class="text-center mb-6">
              <h1 class="text-2xl font-bold text-foreground">Create your account</h1>
              <p class="mt-2 text-sm text-muted-foreground">
                Join the community and start earning rewards
              </p>
            </div>

            <form id="signup-form" class="space-y-4">
              <div>
                <label for="fullName" class="block text-sm font-medium text-foreground mb-1">
                  Full Name
                </label>
                <input
                  type="text"
                  id="fullName"
                  name="fullName"
                  required
                  class="w-full rounded-md border border-input bg-background px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary"
                  placeholder="Enter your full name"
                />
              </div>

              <div>
                <label for="email" class="block text-sm font-medium text-foreground mb-1">
                  Email
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full rounded-md border border-input bg-background px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary"
                  placeholder="you@example.com"
                />
              </div>

              <div>
                <label for="password" class="block text-sm font-medium text-foreground mb-1">
                  Password
                </label>
                <input
                  type="password"
                  id="password"
                  name="password"
                  required
                  minlength="8"
                  class="w-full rounded-md border border-input bg-background px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary"
                  placeholder="Create a strong password"
                />
                <p class="mt-1 text-xs text-muted-foreground">Must be at least 8 characters</p>
              </div>

              <div>
                <label for="confirmPassword" class="block text-sm font-medium text-foreground mb-1">
                  Confirm Password
                </label>
                <input
                  type="password"
                  id="confirmPassword"
                  name="confirmPassword"
                  required
                  minlength="8"
                  class="w-full rounded-md border border-input bg-background px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary"
                  placeholder="Confirm your password"
                />
              </div>

              <div class="flex items-start">
                <input
                  type="checkbox"
                  id="terms"
                  name="terms"
                  required
                  class="mt-1 h-4 w-4 rounded border-gray-300 text-primary focus:ring-primary"
                />
                <label for="terms" class="ml-2 text-sm text-muted-foreground">
                  I agree to the
                  <a href="/terms" class="text-primary hover:underline">Terms of Service</a>
                  and
                  <a href="/privacy" class="text-primary hover:underline">Privacy Policy</a>
                </label>
              </div>

              <button
                type="submit"
                class="w-full rounded-lg bg-primary px-4 py-2.5 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2"
              >
                Create Account
              </button>
            </form>

            <!-- Divider -->
            <div class="relative my-6">
              <div class="absolute inset-0 flex items-center">
                <div class="w-full border-t border-border"></div>
              </div>
              <div class="relative flex justify-center text-sm">
                <span class="bg-surface-elevated px-2 text-muted-foreground">Or continue with</span>
              </div>
            </div>

            <!-- GitHub Signup -->
            <button
              type="button"
              id="github-signup-btn"
              class="w-full inline-flex items-center justify-center gap-3 rounded-lg border border-input bg-background px-4 py-2.5 text-sm font-medium transition-colors hover:bg-accent hover:text-accent-foreground"
            >
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
              Continue with GitHub
            </button>

            <!-- Login Link -->
            <p class="mt-6 text-center text-sm text-muted-foreground">
              Already have an account?
              <a href="/auth/login" class="text-primary font-medium hover:underline">
                Sign in
              </a>
            </p>
          </div>

          <!-- Error/Success Messages (Hidden by default) -->
          <div id="error-message" class="hidden mt-4 rounded-lg bg-red-50 border border-red-200 p-4 text-sm text-red-800 dark:bg-red-900/20 dark:border-red-800 dark:text-red-200">
          </div>
          <div id="success-message" class="hidden mt-4 rounded-lg bg-green-50 border border-green-200 p-4 text-sm text-green-800 dark:bg-green-900/20 dark:border-green-800 dark:text-green-200">
          </div>
        </div>
      </div>

      <!-- Right Side - Features -->
      <div class="hidden lg:flex lg:w-1/2 bg-gradient-to-br from-primary/10 to-accent/10 items-center justify-center p-12">
        <div class="max-w-md">
          <h2 class="text-3xl font-bold text-foreground mb-6">
            Join the EduLaluan Community
          </h2>
          <p class="text-lg text-muted-foreground mb-8">
            Contribute knowledge, earn rewards, and help others access quality education resources.
          </p>
          <ul class="space-y-4">
            {features.map((feature) => (
              <li class="flex items-start gap-3">
                <svg class="h-6 w-6 text-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-foreground">{feature}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  // Signup form handling
  const form = document.getElementById('signup-form');
  const errorMessage = document.getElementById('error-message');
  const successMessage = document.getElementById('success-message');
  const githubSignupBtn = document.getElementById('github-signup-btn');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    console.log('Signup form submitted');

    const formData = new FormData(form as HTMLFormElement);
    const data = {
      fullName: formData.get('fullName'),
      email: formData.get('email'),
      password: formData.get('password'),
      confirmPassword: formData.get('confirmPassword'),
      terms: formData.get('terms') === 'on',
    };

    console.log('Form data:', data);

    // Client-side validation
    if (data.password !== data.confirmPassword) {
      if (errorMessage) {
        errorMessage.textContent = 'Passwords do not match';
        errorMessage.classList.remove('hidden');
      }
      if (successMessage) successMessage.classList.add('hidden');
      return;
    }

    if (!data.terms) {
      if (errorMessage) {
        errorMessage.textContent = 'You must agree to the terms and conditions';
        errorMessage.classList.remove('hidden');
      }
      if (successMessage) successMessage.classList.add('hidden');
      return;
    }

    try {
      console.log('Sending signup request...');
      const response = await fetch('/api/auth/signup', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      console.log('Response status:', response.status);
      const result = await response.json();
      console.log('Response data:', result);

      // Also log response headers for debugging
      console.log('Response headers:', Object.fromEntries(response.headers.entries()));

      if (response.ok) {
        if (successMessage) {
          successMessage.textContent = 'Account created successfully! Signing you in...';
          successMessage.classList.remove('hidden');
        }
        if (errorMessage) errorMessage.classList.add('hidden');

        // Handle session if returned
        const sessionToken = response.headers.get('X-Session-Access-Token');
        const refreshToken = response.headers.get('X-Session-Refresh-Token');
        
        if (sessionToken && refreshToken) {
          // Sign in with the returned tokens
          const { createClient } = await import('@supabase/supabase-js');
          const supabase = createClient(
            import.meta.env.PUBLIC_SUPABASE_URL,
            import.meta.env.PUBLIC_SUPABASE_PUBLISHABLE_KEY || import.meta.env.PUBLIC_SUPABASE_PUBLISHABLE_KEY
          );
          
          await supabase.auth.setSession({
            access_token: sessionToken,
            refresh_token: refreshToken
          });
        }

        // Redirect to dashboard
        setTimeout(() => {
          window.location.href = '/user/dashboard';
        }, 1500);
      } else {
        if (errorMessage) {
          errorMessage.textContent = result.error || 'Failed to create account';
          errorMessage.classList.remove('hidden');
        }
        if (successMessage) successMessage.classList.add('hidden');
      }
    } catch (error) {
      console.error('Signup error:', error);
      if (errorMessage) {
        errorMessage.textContent = 'An unexpected error occurred. Please try again.';
        errorMessage.classList.remove('hidden');
      }
      if (successMessage) successMessage.classList.add('hidden');
    }
  });

  // GitHub OAuth signup
  githubSignupBtn?.addEventListener('click', async () => {
    try {
      const response = await fetch('/api/auth/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ provider: 'github' }),
      });

      const result = await response.json();

      if (response.ok && result.url) {
        // Redirect to GitHub OAuth (will create account if doesn't exist)
        window.location.href = result.url;
      } else {
        if (errorMessage) {
          errorMessage.textContent = result.error || 'Failed to initiate GitHub OAuth';
          errorMessage.classList.remove('hidden');
        }
      }
    } catch (error) {
      if (errorMessage) {
        errorMessage.textContent = 'An unexpected error occurred. Please try again.';
        errorMessage.classList.remove('hidden');
      }
    }
  });
</script>
