---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Brand Kit - EduLaluan">
  <Header />

  <main class="min-h-screen bg-background">
    <!-- Hero Section -->
    <section class="relative py-section-lg bg-gradient-to-br from-primary/10 via-background to-accent/5 overflow-hidden">
      <!-- Decorative batik pattern -->
      <div class="absolute inset-0 opacity-[0.03]" aria-hidden="true">
        <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <pattern id="heroDiamond" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
              <path d="M20 0 L40 20 L20 40 L0 20 Z" fill="none" stroke="currentColor" stroke-width="1" />
            </pattern>
          </defs>
          <rect width="100%" height="100%" fill="url(#heroDiamond)" />
        </svg>
      </div>

      <div class="container relative mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl mx-auto text-center">
          <!-- Eyebrow -->
          <p class="text-sm font-medium text-primary mb-4 tracking-wide uppercase">
            Brand Resources
          </p>

          <!-- Title -->
          <h1 class="font-display text-4xl sm:text-5xl md:text-6xl font-bold mb-6 text-foreground">
            EDULALUAN BRAND KIT
          </h1>

          <!-- Tagline -->
          <p class="text-xl md:text-2xl text-primary mb-6 font-medium">
            Accessible • Collaborative • Empowering
          </p>

          <!-- Description -->
          <p class="text-lg text-muted-foreground mb-8 max-w-2xl mx-auto">
            Here you'll find downloadable assets, color palettes, and guidelines for using the EduLaluan brand.
            All assets are licensed under Apache 2.0.
          </p>

          <!-- CTA -->
          <a
            href="/brand/edulaluan-brand-kit.zip"
            download
            class="inline-flex items-center gap-2 px-8 py-4 bg-primary hover:bg-primary-dark text-primary-foreground font-semibold rounded-lg shadow-lg hover:shadow-xl transition-all duration-300"
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
            Download All Assets
          </a>
        </div>
      </div>
    </section>

    <!-- Logo Section -->
    <section class="py-section-md bg-surface">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-6xl mx-auto">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
            <!-- Logo Preview -->
            <div class="bg-surface-elevated rounded-2xl p-8 md:p-12 border border-border flex items-center justify-center">
              <div class="flex items-center gap-3">
                <svg class="w-16 h-16 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                </svg>
                <span class="font-display text-3xl font-bold text-primary">EduLaluan</span>
              </div>
            </div>

            <!-- Logo Info -->
            <div class="space-y-6">
              <div>
                <h2 class="font-display text-2xl font-bold text-foreground mb-3">Logo</h2>
                <p class="text-muted-foreground mb-4">
                  The EduLaluan logo combines an open book symbol with modern typography, representing accessible education for all Malaysians.
                </p>
              </div>

              <div class="space-y-3">
                <div class="flex items-center justify-between p-3 bg-muted rounded-lg">
                  <span class="text-sm font-medium text-foreground">Primary Logo</span>
                  <a href="/brand/logo-primary.svg" download class="text-primary hover:text-primary-dark text-sm font-medium inline-flex items-center gap-1">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                    </svg>
                    SVG
                  </a>
                </div>
                <div class="flex items-center justify-between p-3 bg-muted rounded-lg">
                  <span class="text-sm font-medium text-foreground">Logo Icon</span>
                  <a href="/brand/icon.svg" download class="text-primary hover:text-primary-dark text-sm font-medium inline-flex items-center gap-1">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                    </svg>
                    SVG
                  </a>
                </div>
                <div class="flex items-center justify-between p-3 bg-muted rounded-lg">
                  <span class="text-sm font-medium text-foreground">Wordmark</span>
                  <a href="/brand/wordmark.svg" download class="text-primary hover:text-primary-dark text-sm font-medium inline-flex items-center gap-1">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                    </svg>
                    SVG
                  </a>
                </div>
              </div>

              <div class="pt-4 border-t border-border">
                <h3 class="font-semibold text-foreground mb-2">Usage Guidelines</h3>
                <ul class="space-y-2 text-sm text-muted-foreground">
                  <li class="flex items-start gap-2">
                    <svg class="w-4 h-4 text-primary mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                    </svg>
                    <span>Maintain clear space around the logo (minimum 1x logo height)</span>
                  </li>
                  <li class="flex items-start gap-2">
                    <svg class="w-4 h-4 text-primary mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                    </svg>
                    <span>Use primary color version on light backgrounds</span>
                  </li>
                  <li class="flex items-start gap-2">
                    <svg class="w-4 h-4 text-primary mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                    </svg>
                    <span>Use white version on dark backgrounds</span>
                  </li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Colors Section -->
    <section class="py-section-md bg-background">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-6xl mx-auto">
          <h2 class="font-display text-3xl font-bold text-foreground mb-8 text-center">Color Palette</h2>

          <!-- Primary Colors -->
          <div class="mb-12">
            <h3 class="font-semibold text-foreground mb-4 text-lg">Primary Colors</h3>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
              <!-- Malaysian Teal -->
              <div class="bg-surface-elevated rounded-xl overflow-hidden border border-border">
                <div class="h-32 bg-[#0d9488]"></div>
                <div class="p-4">
                  <p class="font-semibold text-foreground mb-1">Malaysian Teal</p>
                  <p class="text-xs text-muted-foreground font-mono">#0d9488</p>
                  <p class="text-xs text-muted-foreground mt-1">Primary brand color</p>
                </div>
              </div>

              <!-- Malaysian Teal Light -->
              <div class="bg-surface-elevated rounded-xl overflow-hidden border border-border">
                <div class="h-32 bg-[#2dd4bf]"></div>
                <div class="p-4">
                  <p class="font-semibold text-foreground mb-1">Teal Light</p>
                  <p class="text-xs text-muted-foreground font-mono">#2dd4bf</p>
                  <p class="text-xs text-muted-foreground mt-1">Hover states</p>
                </div>
              </div>

              <!-- Malaysian Teal Dark -->
              <div class="bg-surface-elevated rounded-xl overflow-hidden border border-border">
                <div class="h-32 bg-[#0f766e]"></div>
                <div class="p-4">
                  <p class="font-semibold text-foreground mb-1">Teal Dark</p>
                  <p class="text-xs text-muted-foreground font-mono">#0f766e</p>
                  <p class="text-xs text-muted-foreground mt-1">Active states</p>
                </div>
              </div>

              <!-- Malaysian Gold -->
              <div class="bg-surface-elevated rounded-xl overflow-hidden border border-border">
                <div class="h-32 bg-[#f59e0b]"></div>
                <div class="p-4">
                  <p class="font-semibold text-foreground mb-1">Malaysian Gold</p>
                  <p class="text-xs text-muted-foreground font-mono">#f59e0b</p>
                  <p class="text-xs text-muted-foreground mt-1">Accent color</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Neutral Colors -->
          <div class="mb-12">
            <h3 class="font-semibold text-foreground mb-4 text-lg">Neutral Colors</h3>
            <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
              <!-- Background -->
              <div class="bg-surface-elevated rounded-xl overflow-hidden border border-border">
                <div class="h-24 bg-[#fafcfb]"></div>
                <div class="p-3">
                  <p class="font-medium text-foreground text-sm">Background</p>
                  <p class="text-xs text-muted-foreground font-mono">#fafcfb</p>
                </div>
              </div>

              <!-- Surface -->
              <div class="bg-surface-elevated rounded-xl overflow-hidden border border-border">
                <div class="h-24 bg-[#f5f9f7]"></div>
                <div class="p-3">
                  <p class="font-medium text-foreground text-sm">Surface</p>
                  <p class="text-xs text-muted-foreground font-mono">#f5f9f7</p>
                </div>
              </div>

              <!-- Muted -->
              <div class="bg-surface-elevated rounded-xl overflow-hidden border border-border">
                <div class="h-24 bg-[#ebf1ee]"></div>
                <div class="p-3">
                  <p class="font-medium text-foreground text-sm">Muted</p>
                  <p class="text-xs text-muted-foreground font-mono">#ebf1ee</p>
                </div>
              </div>

              <!-- Foreground -->
              <div class="bg-surface-elevated rounded-xl overflow-hidden border border-border">
                <div class="h-24 bg-[#1e2926]"></div>
                <div class="p-3">
                  <p class="font-medium text-white text-sm">Foreground</p>
                  <p class="text-xs text-muted-foreground font-mono">#1e2926</p>
                </div>
              </div>

              <!-- Border -->
              <div class="bg-surface-elevated rounded-xl overflow-hidden border border-border">
                <div class="h-24 bg-[#dbe5e0]"></div>
                <div class="p-3">
                  <p class="font-medium text-foreground text-sm">Border</p>
                  <p class="text-xs text-muted-foreground font-mono">#dbe5e0</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Semantic Colors -->
          <div>
            <h3 class="font-semibold text-foreground mb-4 text-lg">Semantic Colors</h3>
            <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
              <!-- Success -->
              <div class="bg-surface-elevated rounded-xl overflow-hidden border border-border">
                <div class="h-24 bg-[#22c55e]"></div>
                <div class="p-3">
                  <p class="font-medium text-foreground text-sm">Success</p>
                  <p class="text-xs text-muted-foreground font-mono">#22c55e</p>
                </div>
              </div>

              <!-- Warning -->
              <div class="bg-surface-elevated rounded-xl overflow-hidden border border-border">
                <div class="h-24 bg-[#f59e0b]"></div>
                <div class="p-3">
                  <p class="font-medium text-foreground text-sm">Warning</p>
                  <p class="text-xs text-muted-foreground font-mono">#f59e0b</p>
                </div>
              </div>

              <!-- Error -->
              <div class="bg-surface-elevated rounded-xl overflow-hidden border border-border">
                <div class="h-24 bg-[#ef4444]"></div>
                <div class="p-3">
                  <p class="font-medium text-white text-sm">Error</p>
                  <p class="text-xs text-muted-foreground font-mono">#ef4444</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Typography Section -->
    <section class="py-section-md bg-surface">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-6xl mx-auto">
          <h2 class="font-display text-3xl font-bold text-foreground mb-8 text-center">Typography</h2>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <!-- Playfair Display -->
            <div class="bg-surface-elevated rounded-2xl p-8 border border-border">
              <h3 class="font-semibold text-foreground mb-4">Playfair Display</h3>
              <p class="text-sm text-muted-foreground mb-6">Serif font for headings and display text</p>

              <div class="space-y-4">
                <div>
                  <p class="font-display text-5xl font-bold text-foreground">Aa</p>
                  <p class="text-xs text-muted-foreground mt-2">Display / H1</p>
                </div>
                <div>
                  <p class="font-display text-3xl font-bold text-foreground">The quick brown fox</p>
                  <p class="text-xs text-muted-foreground mt-2">H2 / H3</p>
                </div>
                <div>
                  <p class="font-display text-xl font-semibold text-foreground">Education for all Malaysians</p>
                  <p class="text-xs text-muted-foreground mt-2">H4 / H5</p>
                </div>
              </div>

              <div class="mt-6 pt-6 border-t border-border">
                <a href="https://fonts.google.com/specimen/Playfair+Display" target="_blank" rel="noopener noreferrer" class="text-primary hover:text-primary-dark text-sm font-medium inline-flex items-center gap-1">
                  View on Google Fonts
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </a>
              </div>
            </div>

            <!-- Sora -->
            <div class="bg-surface-elevated rounded-2xl p-8 border border-border">
              <h3 class="font-semibold text-foreground mb-4">Sora</h3>
              <p class="text-sm text-muted-foreground mb-6">Sans-serif font for body text and UI</p>

              <div class="space-y-4">
                <div>
                  <p class="font-sans text-2xl font-bold text-foreground">Aa Bb Cc</p>
                  <p class="text-xs text-muted-foreground mt-2">Bold / Headings</p>
                </div>
                <div>
                  <p class="font-sans text-base text-foreground">The quick brown fox jumps over the lazy dog. EduLaluan provides accessible education resources for Malaysian B40, M40 & T20 communities.</p>
                  <p class="text-xs text-muted-foreground mt-2">Body / Paragraphs</p>
                </div>
                <div>
                  <p class="font-sans text-sm text-muted-foreground">Small text for captions, labels, and secondary information.</p>
                  <p class="text-xs text-muted-foreground mt-2">Small / Captions</p>
                </div>
              </div>

              <div class="mt-6 pt-6 border-t border-border">
                <a href="https://fonts.google.com/specimen/Sora" target="_blank" rel="noopener noreferrer" class="text-primary hover:text-primary-dark text-sm font-medium inline-flex items-center gap-1">
                  View on Google Fonts
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Iconography Section -->
    <section class="py-section-md bg-background">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-6xl mx-auto">
          <h2 class="font-display text-3xl font-bold text-foreground mb-8 text-center">Iconography</h2>

          <div class="bg-surface-elevated rounded-2xl p-8 border border-border">
            <p class="text-muted-foreground mb-6 text-center max-w-2xl mx-auto">
              EduLaluan uses a consistent icon style with rounded corners and 2px stroke weight. Icons should maintain visual harmony with the brand's modern, approachable aesthetic.
            </p>

            <!-- Icon Grid -->
            <div class="grid grid-cols-4 md:grid-cols-8 gap-6 mb-8">
              <!-- Education Icon -->
              <div class="flex flex-col items-center">
                <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center mb-2">
                  <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253" />
                  </svg>
                </div>
                <span class="text-xs text-muted-foreground">Education</span>
              </div>

              <!-- Search Icon -->
              <div class="flex flex-col items-center">
                <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center mb-2">
                  <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                  </svg>
                </div>
                <span class="text-xs text-muted-foreground">Search</span>
              </div>

              <!-- Filter Icon -->
              <div class="flex flex-col items-center">
                <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center mb-2">
                  <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
                  </svg>
                </div>
                <span class="text-xs text-muted-foreground">Filter</span>
              </div>

              <!-- Download Icon -->
              <div class="flex flex-col items-center">
                <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center mb-2">
                  <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                  </svg>
                </div>
                <span class="text-xs text-muted-foreground">Download</span>
              </div>

              <!-- External Link Icon -->
              <div class="flex flex-col items-center">
                <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center mb-2">
                  <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </div>
                <span class="text-xs text-muted-foreground">External</span>
              </div>

              <!-- Check Icon -->
              <div class="flex flex-col items-center">
                <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center mb-2">
                  <svg class="w-6 h-6 text-primary" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                  </svg>
                </div>
                <span class="text-xs text-muted-foreground">Check</span>
              </div>

              <!-- Arrow Icon -->
              <div class="flex flex-col items-center">
                <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center mb-2">
                  <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                  </svg>
                </div>
                <span class="text-xs text-muted-foreground">Arrow</span>
              </div>

              <!-- Users Icon -->
              <div class="flex flex-col items-center">
                <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center mb-2">
                  <svg class="w-6 h-6 text-primary" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z" />
                  </svg>
                </div>
                <span class="text-xs text-muted-foreground">Users</span>
              </div>
            </div>

            <div class="text-center">
              <a href="/brand/icons.svg" download class="inline-flex items-center gap-2 px-6 py-3 bg-primary hover:bg-primary-dark text-primary-foreground font-semibold rounded-lg transition-all">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
