---
// Admin Settings - Platform configuration
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdminSidebar from '../../components/admin/AdminSidebar.astro';

const currentPage = 'settings';
---

<Layout title="Admin Settings | EduLaluan">
  <Header />

  <div class="flex min-h-screen">
    <!-- Admin Sidebar -->
    <AdminSidebar current={currentPage} />

    <!-- Main Content -->
    <main class="flex-1 bg-surface p-8">
      <!-- Page Header -->
      <div class="mb-8">
        <h1 class="text-3xl font-bold text-foreground">Settings</h1>
        <p class="mt-2 text-sm text-muted-foreground">
          Platform configuration and feature toggles
        </p>
      </div>

      <!-- Settings Form -->
      <div class="max-w-2xl rounded-xl border bg-surface-elevated p-6 shadow-sm">
        <form id="settings-form" class="space-y-6">
          <!-- Demo Data Toggle -->
          <div class="flex items-start justify-between pb-6 border-b">
            <div class="space-y-1">
              <label for="demo-data" class="text-base font-semibold text-foreground">
                Demo Data Mode
              </label>
              <p class="text-sm text-muted-foreground">
                Allow demo user accounts and sample data for testing
              </p>
            </div>
            <button
              type="button"
              role="switch"
              aria-checked="true"
              id="demo-data"
              name="demoDataEnabled"
              class="relative inline-flex h-6 w-11 flex-shrink-0 cursor-pointer rounded-full border-2 border-transparent transition-colors duration-200 ease-in-out focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2"
              style="background-color: #059669;"
            >
              <span
                aria-hidden="true"
                class="translate-x-5 pointer-events-none inline-block h-5 w-5 transform rounded-full bg-white shadow ring-0 transition duration-200 ease-in-out"
              ></span>
            </button>
          </div>

          <!-- Public Contributions Toggle -->
          <div class="flex items-start justify-between pb-6 border-b">
            <div class="space-y-1">
              <label for="public-contributions" class="text-base font-semibold text-foreground">
                Public Contributions
              </label>
              <p class="text-sm text-muted-foreground">
                Allow non-admin users to submit resources and content
              </p>
            </div>
            <button
              type="button"
              role="switch"
              aria-checked="true"
              id="public-contributions"
              name="allowPublicContributions"
              class="relative inline-flex h-6 w-11 flex-shrink-0 cursor-pointer rounded-full border-2 border-transparent transition-colors duration-200 ease-in-out focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2"
              style="background-color: #059669;"
            >
              <span
                aria-hidden="true"
                class="translate-x-5 pointer-events-none inline-block h-5 w-5 transform rounded-full bg-white shadow ring-0 transition duration-200 ease-in-out"
              ></span>
            </button>
          </div>

          <!-- Email Verification Toggle -->
          <div class="flex items-start justify-between pb-6 border-b">
            <div class="space-y-1">
              <label for="email-verification" class="text-base font-semibold text-foreground">
                Email Verification Required
              </label>
              <p class="text-sm text-muted-foreground">
                Require users to verify their email before contributing
              </p>
            </div>
            <button
              type="button"
              role="switch"
              aria-checked="true"
              id="email-verification"
              name="requireEmailVerification"
              class="relative inline-flex h-6 w-11 flex-shrink-0 cursor-pointer rounded-full border-2 border-transparent transition-colors duration-200 ease-in-out focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2"
              style="background-color: #059669;"
            >
              <span
                aria-hidden="true"
                class="translate-x-5 pointer-events-none inline-block h-5 w-5 transform rounded-full bg-white shadow ring-0 transition duration-200 ease-in-out"
              ></span>
            </button>
          </div>

          <!-- Maintenance Mode Toggle -->
          <div class="flex items-start justify-between">
            <div class="space-y-1">
              <label for="maintenance-mode" class="text-base font-semibold text-foreground">
                Maintenance Mode
              </label>
              <p class="text-sm text-muted-foreground">
                Disable all user contributions during maintenance
              </p>
            </div>
            <button
              type="button"
              role="switch"
              aria-checked="false"
              id="maintenance-mode"
              name="maintenanceMode"
              class="relative inline-flex h-6 w-11 flex-shrink-0 cursor-pointer rounded-full border-2 border-transparent transition-colors duration-200 ease-in-out focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2"
              style="background-color: #9CA3AF;"
            >
              <span
                aria-hidden="true"
                class="translate-x-0 pointer-events-none inline-block h-5 w-5 transform rounded-full bg-white shadow ring-0 transition duration-200 ease-in-out"
              ></span>
            </button>
          </div>
        </form>

        <!-- Save Button -->
        <div class="mt-6 pt-6 border-t flex items-center justify-between">
          <p id="save-status" class="text-sm text-muted-foreground"></p>
          <button
            type="button"
            id="save-settings"
            class="inline-flex items-center justify-center rounded-lg px-4 py-2 text-sm font-semibold shadow-sm transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2"
            style="background-color: #059669; color: white;"
            onmouseover="this.style.backgroundColor='#047857'"
            onmouseout="this.style.backgroundColor='#059669'"
          >
            Save Settings
          </button>
        </div>
      </div>

      <!-- Stats Section -->
      <div class="mt-8 grid gap-6 sm:grid-cols-2">
        <!-- Demo Users Count -->
        <div class="rounded-xl border bg-surface-elevated p-6 shadow-sm">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-medium text-muted-foreground">Demo Users</p>
              <p id="demo-users-count" class="text-3xl font-bold text-foreground mt-2">-</p>
            </div>
            <div class="rounded-full bg-blue-500/10 p-3">
              <svg class="h-6 w-6 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
              </svg>
            </div>
          </div>
          <p class="mt-4 text-sm text-muted-foreground">
            Active demo accounts in the system
          </p>
        </div>

        <!-- Pending Contributions -->
        <div class="rounded-xl border bg-surface-elevated p-6 shadow-sm">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-medium text-muted-foreground">Pending Review</p>
              <p id="pending-contributions" class="text-3xl font-bold text-foreground mt-2">-</p>
            </div>
            <div class="rounded-full bg-amber-500/10 p-3">
              <svg class="h-6 w-6 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
              </svg>
            </div>
          </div>
          <p class="mt-4 text-sm text-muted-foreground">
            Contributions awaiting moderation
          </p>
        </div>
      </div>
    </main>
  </div>

  <Footer />
</Layout>

<script>
  // Toggle switch behavior
  function setupToggle(id: string) {
    const toggle = document.getElementById(id) as HTMLElement;
    if (!toggle) return;

    toggle.addEventListener('click', () => {
      const isChecked = toggle.getAttribute('aria-checked') === 'true';
      const span = toggle.querySelector('span');

      toggle.setAttribute('aria-checked', String(!isChecked));

      if (!isChecked) {
        // Turn on - green
        toggle.style.backgroundColor = '#059669';
        span?.classList.remove('translate-x-0');
        span?.classList.add('translate-x-5');
      } else {
        // Turn off - gray
        toggle.style.backgroundColor = '#9CA3AF';
        span?.classList.remove('translate-x-5');
        span?.classList.add('translate-x-0');
      }
    });
  }

  // Initialize toggles
  setupToggle('demo-data');
  setupToggle('public-contributions');
  setupToggle('email-verification');
  setupToggle('maintenance-mode');

  // Load settings on page load
  async function loadSettings() {
    try {
      // Get access token from localStorage (OAuth implicit flow stores it there)
      // Storage key format: sb-{project-ref}-auth-token
      const storageData = localStorage.getItem('sb-ngpqiaiwxnfyjsvcmxpe-auth-token');
      let accessToken = null;

      if (storageData) {
        try {
          const parsed = JSON.parse(storageData);
          accessToken = parsed.access_token;
        } catch (e) {
          console.warn('Failed to parse auth token from localStorage:', e);
        }
      }

      const headers: HeadersInit = {
        'Content-Type': 'application/json'
      };

      if (accessToken) {
        headers['Authorization'] = `Bearer ${accessToken}`;
      }

      const response = await fetch('/api/admin/settings', {
        method: 'GET',
        headers
      });

      if (!response.ok) {
        const errorData = await response.json();
        throw new Error(errorData.error || 'Failed to load settings');
      }

      const data = await response.json();

      if (data.success) {
        // Update toggles based on settings
        updateToggle('demo-data', data.settings.demoDataEnabled);
        updateToggle('public-contributions', data.settings.allowPublicContributions);
        updateToggle('email-verification', data.settings.requireEmailVerification);
        updateToggle('maintenance-mode', data.settings.maintenanceMode);

        // Update stats
        document.getElementById('demo-users-count')!.textContent = String(data.stats.demoUsersCount);
        document.getElementById('pending-contributions')!.textContent = String(data.stats.pendingContributions);
      }
    } catch (error) {
      console.error('Error loading settings:', error);
      document.getElementById('save-status')!.textContent = error instanceof Error ? error.message : 'Failed to load settings';
      document.getElementById('save-status')!.classList.add('text-red-600');
    }
  }

  function updateToggle(id: string, enabled: boolean) {
    const toggle = document.getElementById(id) as HTMLElement;
    const span = toggle?.querySelector('span');
    if (!toggle || !span) return;

    toggle.setAttribute('aria-checked', String(enabled));

    if (enabled) {
      // Turn on - green
      toggle.style.backgroundColor = '#059669';
      span.classList.remove('translate-x-0');
      span.classList.add('translate-x-5');
    } else {
      // Turn off - gray
      toggle.style.backgroundColor = '#9CA3AF';
      span.classList.remove('translate-x-5');
      span.classList.add('translate-x-0');
    }
  }

  // Save settings
  document.getElementById('save-settings')?.addEventListener('click', async () => {
    const statusEl = document.getElementById('save-status');
    if (!statusEl) return;

    const settings = {
      demoDataEnabled: document.getElementById('demo-data')?.getAttribute('aria-checked') === 'true',
      allowPublicContributions: document.getElementById('public-contributions')?.getAttribute('aria-checked') === 'true',
      requireEmailVerification: document.getElementById('email-verification')?.getAttribute('aria-checked') === 'true',
      maintenanceMode: document.getElementById('maintenance-mode')?.getAttribute('aria-checked') === 'true'
    };

    try {
      statusEl.textContent = 'Saving...';
      statusEl.classList.remove('text-red-600', 'text-green-600');

      // Get access token from localStorage (OAuth implicit flow stores it there)
      // Storage key format: sb-{project-ref}-auth-token
      const storageData = localStorage.getItem('sb-ngpqiaiwxnfyjsvcmxpe-auth-token');
      let accessToken = null;

      if (storageData) {
        try {
          const parsed = JSON.parse(storageData);
          accessToken = parsed.access_token;
        } catch (e) {
          console.warn('Failed to parse auth token from localStorage:', e);
        }
      }

      const headers: HeadersInit = {
        'Content-Type': 'application/json'
      };

      if (accessToken) {
        headers['Authorization'] = `Bearer ${accessToken}`;
      }

      const response = await fetch('/api/admin/settings', {
        method: 'PUT',
        headers,
        body: JSON.stringify(settings)
      });

      const data = await response.json();

      if (!response.ok) {
        throw new Error(data.error || 'Failed to save settings');
      }

      statusEl.textContent = 'Settings saved successfully!';
      statusEl.classList.add('text-green-600');

      setTimeout(() => {
        statusEl.textContent = '';
        statusEl.classList.remove('text-green-600');
      }, 3000);
    } catch (error: any) {
      console.error('Error saving settings:', error);
      statusEl.textContent = error.message || 'Failed to save settings';
      statusEl.classList.add('text-red-600');
    }
  });

  // Load settings on mount
  loadSettings();
</script>
