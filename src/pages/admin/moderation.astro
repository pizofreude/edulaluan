---
// Admin Moderation Queue Page
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdminSidebar from '../../components/admin/AdminSidebar.astro';

const currentPage = 'moderation';
---

<Layout title="Moderation Queue | EduLaluan">
  <Header />

  <div class="flex min-h-screen">
    <!-- Admin Sidebar -->
    <AdminSidebar current={currentPage} />

    <!-- Main Content -->
    <main class="flex-1 bg-surface p-8">
      <!-- Page Header -->
      <div class="mb-8">
        <h1 class="text-3xl font-bold text-foreground">📋 Moderation Queue</h1>
        <p class="mt-2 text-sm text-muted-foreground">
          Review and approve user submissions
        </p>
      </div>

      <!-- Stats Cards -->
      <div class="grid gap-6 sm:grid-cols-4 mb-8">
        <div class="rounded-xl border bg-surface-elevated p-6 shadow-sm">
          <div class="flex items-center gap-4">
            <div class="rounded-full bg-amber-500/10 p-3">
              <svg class="h-6 w-6 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <p class="text-sm font-semibold text-foreground">Pending</p>
              <p id="pending-count" class="text-2xl font-bold text-amber-600">-</p>
            </div>
          </div>
        </div>

        <div class="rounded-xl border bg-surface-elevated p-6 shadow-sm">
          <div class="flex items-center gap-4">
            <div class="rounded-full bg-green-500/10 p-3">
              <svg class="h-6 w-6 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <p class="text-sm font-semibold text-foreground">Approved Today</p>
              <p id="approved-today-count" class="text-2xl font-bold text-green-600">-</p>
            </div>
          </div>
        </div>

        <div class="rounded-xl border bg-surface-elevated p-6 shadow-sm">
          <div class="flex items-center gap-4">
            <div class="rounded-full bg-red-500/10 p-3">
              <svg class="h-6 w-6 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <p class="text-sm font-semibold text-foreground">Rejected</p>
              <p id="rejected-count" class="text-2xl font-bold text-red-600">-</p>
            </div>
          </div>
        </div>

        <div class="rounded-xl border bg-surface-elevated p-6 shadow-sm">
          <div class="flex items-center gap-4">
            <div class="rounded-full bg-blue-500/10 p-3">
              <svg class="h-6 w-6 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
            </div>
            <div>
              <p class="text-sm font-semibold text-foreground">Total</p>
              <p id="total-count" class="text-2xl font-bold text-blue-600">-</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Filters -->
      <div class="rounded-xl border bg-surface-elevated p-4 mb-6">
        <div class="flex flex-wrap items-center gap-4">
          <!-- Type Filter -->
          <div class="flex items-center gap-2">
            <label for="type-filter" class="text-sm font-medium text-foreground">Type:</label>
            <select
              id="type-filter"
              class="rounded-md border border-input bg-background px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary"
            >
              <option value="all">All Types</option>
              <option value="resource">Resources</option>
              <option value="financial_aid">Financial Aid</option>
              <option value="feature_request">Feature Requests</option>
              <option value="circumcision">Circumcision</option>
            </select>
          </div>

          <!-- Status Filter -->
          <div class="flex items-center gap-2">
            <label for="status-filter" class="text-sm font-medium text-foreground">Status:</label>
            <select
              id="status-filter"
              class="rounded-md border border-input bg-background px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary"
            >
              <option value="pending">Pending</option>
              <option value="approved">Approved</option>
              <option value="rejected">Rejected</option>
              <option value="changes_requested">Changes Requested</option>
            </select>
          </div>

          <!-- Search -->
          <div class="flex-1 min-w-64">
            <div class="relative">
              <svg
                class="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-muted-foreground"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
              <input
                type="text"
                id="search-input"
                placeholder="Search by title or username..."
                class="w-full rounded-md border border-input bg-background pl-10 pr-4 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary"
              />
            </div>
          </div>

          <!-- Refresh Button -->
          <button
            id="refresh-btn"
            class="px-4 py-2 bg-primary hover:bg-primary/90 text-white rounded-md text-sm font-medium transition-colors"
          >
            🔄 Refresh
          </button>
        </div>
      </div>

      <!-- Loading State -->
      <div id="loading-state" class="rounded-xl border bg-surface-elevated p-12 text-center">
        <div class="inline-block animate-spin rounded-full h-8 w-8 border-4 border-primary border-t-transparent"></div>
        <p class="text-muted-foreground mt-4">Loading submissions...</p>
      </div>

      <!-- Submissions List -->
      <div id="submissions-list" class="rounded-xl border bg-surface-elevated overflow-hidden hidden">
        <!-- Will be populated by JavaScript -->
      </div>

      <!-- Empty State -->
      <div id="empty-state" class="rounded-xl border bg-surface-elevated p-12 text-center hidden">
        <svg class="mx-auto h-16 w-16 text-muted-foreground/50" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        <h3 class="mt-4 text-lg font-semibold text-foreground">No submissions found</h3>
        <p class="mt-2 text-sm text-muted-foreground">Adjust your filters or check back later</p>
      </div>

    </div>
  </main>

  <Footer />
</Layout>

<script>
  let allSubmissions: any[] = [];
  let filteredSubmissions: any[] = [];

  // Load submissions on page load
  loadSubmissions();

  // Event listeners
  document.getElementById('type-filter')?.addEventListener('change', filterSubmissions);
  document.getElementById('status-filter')?.addEventListener('change', filterSubmissions);
  document.getElementById('search-input')?.addEventListener('input', filterSubmissions);
  document.getElementById('refresh-btn')?.addEventListener('click', loadSubmissions);

  async function loadSubmissions() {
    try {
      // Get access token from localStorage
      const storageData = localStorage.getItem('sb-ngpqiaiwxnfyjsvcmxpe-auth-token');
      let accessToken = null;
      
      if (storageData) {
        try {
          const parsed = JSON.parse(storageData);
          accessToken = parsed.access_token;
        } catch (e) {
          console.warn('Failed to parse auth token from localStorage:', e);
        }
      }

      const headers: Record<string, string> = { 'Content-Type': 'application/json' };
      if (accessToken) {
        headers['Authorization'] = `Bearer ${accessToken}`;
      }

      const response = await fetch('/api/admin/contributions?status=pending', { headers });
      const data = await response.json();

      if (!response.ok) throw new Error(data.error);

      allSubmissions = data.contributions || [];
      filteredSubmissions = [...allSubmissions];

      updateStats();
      renderSubmissions();
    } catch (error) {
      console.error('Failed to load submissions:', error);
      showError('Failed to load submissions');
    }
  }

  function filterSubmissions() {
    const typeFilter = (document.getElementById('type-filter') as HTMLSelectElement).value;
    const statusFilter = (document.getElementById('status-filter') as HTMLSelectElement).value;
    const searchTerm = (document.getElementById('search-input') as HTMLInputElement).value.toLowerCase();

    filteredSubmissions = allSubmissions.filter(sub => {
      const matchesType = typeFilter === 'all' || sub.type === typeFilter;
      const matchesStatus = statusFilter === 'all' || sub.status === statusFilter;
      const matchesSearch = !searchTerm || 
        sub.title.toLowerCase().includes(searchTerm) ||
        sub.user?.email?.toLowerCase().includes(searchTerm) ||
        sub.user?.full_name?.toLowerCase().includes(searchTerm);
      
      return matchesType && matchesStatus && matchesSearch;
    });

    renderSubmissions();
    updateStats();
  }

  function updateStats() {
    const pending = allSubmissions.filter(s => s.status === 'pending').length;
    const today = new Date().toISOString().split('T')[0];
    const approvedToday = allSubmissions.filter(s => 
      s.status === 'approved' && s.moderated_at?.startsWith(today)
    ).length;
    const rejected = allSubmissions.filter(s => s.status === 'rejected').length;

    document.getElementById('pending-count')!.textContent = pending.toString();
    document.getElementById('approved-today-count')!.textContent = approvedToday.toString();
    document.getElementById('rejected-count')!.textContent = rejected.toString();
    document.getElementById('total-count')!.textContent = allSubmissions.length.toString();
  }

  function renderSubmissions() {
    const container = document.getElementById('submissions-list')!;
    const loadingState = document.getElementById('loading-state')!;
    const emptyState = document.getElementById('empty-state')!;

    loadingState.classList.add('hidden');

    if (filteredSubmissions.length === 0) {
      container.classList.add('hidden');
      emptyState.classList.remove('hidden');
      return;
    }

    container.classList.remove('hidden');
    emptyState.classList.add('hidden');

    container.innerHTML = `
      <div class="divide-y divide-border">
        ${filteredSubmissions.map(renderSubmission).join('')}
      </div>
    `;

    // Add event listeners to action buttons
    container.querySelectorAll('[data-action]').forEach(btn => {
      btn.addEventListener('click', handleAction);
    });
  }

  function renderSubmission(sub: any) {
    const typeColors: Record<string, string> = {
      resource: 'bg-blue-100 text-blue-800',
      financial_aid: 'bg-green-100 text-green-800',
      feature_request: 'bg-purple-100 text-purple-800',
      circumcision: 'bg-amber-100 text-amber-800'
    };

    const typeColor = typeColors[sub.type] || 'bg-gray-100 text-gray-800';

    return `
      <div class="p-6 hover:bg-surface/50 transition-colors" data-id="${sub.id}">
        <div class="flex items-start justify-between gap-4">
          <div class="flex-1">
            <div class="flex items-center gap-3 mb-2">
              <span class="px-3 py-1 rounded-full text-xs font-semibold ${typeColor}">
                ${sub.type.replace('_', ' ').toUpperCase()}
              </span>
              <span class="text-xs text-muted-foreground">
                Submitted ${new Date(sub.submitted_at).toLocaleDateString()}
              </span>
            </div>
            
            <h3 class="text-lg font-semibold text-foreground mb-2">${escapeHtml(sub.title)}</h3>
            <p class="text-sm text-muted-foreground mb-3 line-clamp-2">${escapeHtml(sub.description || 'No description')}</p>
            
            <div class="flex items-center gap-4 text-sm">
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
                <span class="text-foreground">${escapeHtml(sub.is_anonymous ? 'Anonymous' : sub.user?.username || sub.user?.full_name || sub.user?.email || sub.metadata?.submitter_name || 'Unknown')}</span>
              </div>
              ${sub.url ? `
                <div class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
                  </svg>
                  <a href="${sub.url}" target="_blank" class="text-primary hover:underline">${new URL(sub.url).hostname}</a>
                </div>
              ` : ''}
            </div>
          </div>

          <div class="flex flex-col gap-2">
            ${sub.status === 'pending' ? `
              <button data-action="approve" data-id="${sub.id}" class="px-4 py-2 bg-green-600 hover:bg-green-700 text-white rounded-md text-sm font-medium transition-colors flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                Approve
              </button>
              <button data-action="reject" data-id="${sub.id}" class="px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-md text-sm font-medium transition-colors flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
                Reject
              </button>
              <button data-action="changes" data-id="${sub.id}" class="px-4 py-2 bg-amber-600 hover:bg-amber-700 text-white rounded-md text-sm font-medium transition-colors flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                Request Changes
              </button>
            ` : `
              <span class="px-4 py-2 bg-gray-100 text-gray-600 rounded-md text-sm font-medium text-center capitalize">
                ${sub.status.replace('_', ' ')}
              </span>
            `}
          </div>
        </div>
      </div>
    `;
  }

  async function handleAction(e: Event) {
    const btn = e.currentTarget as HTMLButtonElement;
    const action = btn.dataset.action;
    const contributionId = btn.dataset.id;

    if (!contributionId) return;

    const submission = allSubmissions.find(s => s.id === contributionId);
    if (!submission) return;

    let moderatorNotes = '';
    let apiUrl = '';
    let successMessage = '';

    if (action === 'approve') {
      moderatorNotes = prompt('Add moderator notes (optional):') || '';
      apiUrl = `/api/admin/contributions/${contributionId}/approve`;
      successMessage = 'Contribution approved! Points awarded to user.';
    } else if (action === 'reject') {
      moderatorNotes = prompt('Reason for rejection (required):') || '';
      if (!moderatorNotes) return;
      apiUrl = `/api/admin/contributions/${contributionId}/reject`;
      successMessage = 'Contribution rejected. User notified.';
    } else if (action === 'changes') {
      moderatorNotes = prompt('Changes required (required):') || '';
      if (!moderatorNotes) return;
      apiUrl = `/api/admin/contributions/${contributionId}/request-changes`;
      successMessage = 'Changes requested. User notified.';
    }

    try {
      btn.disabled = true;
      btn.innerHTML = '<span class="animate-spin">⏳</span> Processing...';

      const response = await fetch(apiUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ moderatorNotes })
      });

      const result = await response.json();

      if (!response.ok) throw new Error(result.error);

      alert(successMessage);
      
      // Reload submissions
      await loadSubmissions();
    } catch (error: any) {
      console.error('Action failed:', error);
      alert('Failed to process: ' + error.message);
      btn.disabled = false;
      // Restore button text
      if (action === 'approve') btn.innerHTML = '✓ Approve';
      if (action === 'reject') btn.innerHTML = '✕ Reject';
      if (action === 'changes') btn.innerHTML = '⚠ Request Changes';
    }
  }

  function showError(message: string) {
    const container = document.getElementById('submissions-list')!;
    const loadingState = document.getElementById('loading-state')!;
    
    loadingState.classList.add('hidden');
    container.classList.add('hidden');
    
    const emptyState = document.getElementById('empty-state')!;
    emptyState.classList.remove('hidden');
    emptyState.querySelector('h3')!.textContent = 'Error';
    emptyState.querySelector('p')!.textContent = message;
  }

  function escapeHtml(text: string): string {
    if (!text) return '';
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }
</script>
