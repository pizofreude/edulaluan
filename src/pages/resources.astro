---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ResourcesPage from '../components/ResourcesPage';
---

<Layout title="All Resources - EduLaluan">
  <Header />

  <main class="min-h-screen bg-slate-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="mb-8">
        <h1 class="text-4xl font-bold mb-4">Educational Resources</h1>
        <p class="text-xl text-muted-foreground">
          Browse our complete collection of educational opportunities for Malaysian communities.
        </p>
      </div>

      <ResourcesPage client:load />
    </div>
  </main>

  <Footer />
</Layout>

