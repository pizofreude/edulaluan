---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { Button } from '../../components/ui/button';
---

<Layout title="Submit Education Resource - EduLaluan">
  <Header />

  <main class="min-h-screen bg-background">
    <div class="container mx-auto px-4 py-8 max-w-3xl">

      <!-- Header -->
      <div class="mb-8">
        <a href="/contribute" class="text-primary hover:text-primary-dark mb-4 inline-block">
          ← Back to Contribute
        </a>
        <h1 class="font-display text-3xl font-bold text-foreground mb-2">
          📚 Submit Education Resource
        </h1>
        <p class="text-muted-foreground">
          Share an educational resource that can help Malaysian families. All fields marked with * are required.
        </p>
      </div>

    <!-- Form -->
    <form
      id="resource-form"
      class="bg-surface border rounded-lg p-6 space-y-6"
    >

      <!-- Status Messages -->
      <div id="form-status" class="hidden rounded-lg p-4"></div>
      <div id="form-loading" class="hidden text-center py-4">
        <div class="inline-block animate-spin rounded-full h-8 w-8 border-4 border-primary border-t-transparent"></div>
        <p class="mt-2 text-muted-foreground">Submitting your resource...</p>
      </div>

      <!-- Basic Information -->
      <div class="space-y-4">
        <h2 class="text-xl font-semibold text-foreground border-b border-border pb-2">Basic Information</h2>

        <div>
          <label for="resourceName" class="block text-sm font-medium text-foreground mb-1">
            Resource Name *
          </label>
          <input
            type="text"
            id="resourceName"
            name="resourceName"
            required
            class="w-full px-3 py-2 border border-border rounded-md bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-primary"
            placeholder="e.g., Khan Academy Computer Science"
          />
        </div>

        <div>
          <label for="provider" class="block text-sm font-medium text-foreground mb-1">
            Provider/Organization *
          </label>
          <input
            type="text"
            id="provider"
            name="provider"
            required
            class="w-full px-3 py-2 border border-border rounded-md bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-primary"
            placeholder="e.g., Khan Academy"
          />
        </div>

        <div>
          <label for="url" class="block text-sm font-medium text-foreground mb-1">
            Website URL *
          </label>
          <input
            type="url"
            id="url"
            name="url"
            required
            class="w-full px-3 py-2 border border-border rounded-md bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-primary"
            placeholder="https://example.com"
          />
          <p class="text-xs text-muted-foreground mt-1">Official website URL only (no shortened links)</p>
        </div>

        <div>
          <label for="description" class="block text-sm font-medium text-foreground mb-1">
            Description * (150-500 words)
          </label>
          <textarea
            id="description"
            name="description"
            required
            rows="6"
            minlength="150"
            maxlength="3000"
            class="w-full px-3 py-2 border border-border rounded-md bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-primary"
            placeholder="Describe the resource: What is it? Who is it for? What does it offer? How can students access it?"
          ></textarea>
          <p class="text-xs text-muted-foreground mt-1">Minimum 150 characters. Be clear and informative.</p>
        </div>
      </div>

      <!-- Category & Details -->
      <div class="space-y-4">
        <h2 class="text-xl font-semibold text-foreground border-b border-border pb-2">Category & Details</h2>

        <div>
          <label for="category" class="block text-sm font-medium text-foreground mb-1">
            Category *
          </label>
          <select
            id="category"
            name="category"
            required
            class="w-full px-3 py-2 border border-border rounded-md bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-primary"
          >
            <option value="">-- Select Category --</option>
            <option value="scholarship">Scholarship</option>
            <option value="mooc">MOOC / Free Online Course</option>
            <option value="tvet">TVET / Vocational Training</option>
            <option value="financial-aid">Financial Aid / Loan</option>
            <option value="digital-skills">Digital Skills / Coding</option>
            <option value="degree">Degree Program / University</option>
            <option value="secondary-education">Secondary Education / Boarding School</option>
            <option value="community">Community Initiative</option>
            <option value="other">Other</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-foreground mb-2">
            Income Group Applicability * (select at least one)
          </label>
          <div class="space-y-2">
            <label class="flex items-center gap-2 text-foreground">
              <input type="checkbox" name="incomeGroups" value="B40" class="rounded" />
              <span>B40 (&lt; RM4,850/month)</span>
            </label>
            <label class="flex items-center gap-2 text-foreground">
              <input type="checkbox" name="incomeGroups" value="M40" class="rounded" />
              <span>M40 (RM4,850-10,970/month)</span>
            </label>
            <label class="flex items-center gap-2 text-foreground">
              <input type="checkbox" name="incomeGroups" value="T20" class="rounded" />
              <span>T20 (&gt; RM10,970/month)</span>
            </label>
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-foreground mb-2">
            Cost Structure *
          </label>
          <div class="space-y-2">
            <label class="flex items-center gap-2 text-foreground">
              <input type="radio" name="cost" value="free" required />
              <span>Free (no cost)</span>
            </label>
            <label class="flex items-center gap-2 text-foreground">
              <input type="radio" name="cost" value="subsidized" required />
              <span>Subsidized (partially funded)</span>
            </label>
            <label class="flex items-center gap-2 text-foreground">
              <input type="radio" name="cost" value="paid" required />
              <span>Paid (full cost required)</span>
            </label>
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-foreground mb-2">
            Delivery Mode *
          </label>
          <div class="space-y-2">
            <label class="flex items-center gap-2 text-foreground">
              <input type="radio" name="mode" value="online" required />
              <span>Online</span>
            </label>
            <label class="flex items-center gap-2 text-foreground">
              <input type="radio" name="mode" value="in-person" required />
              <span>In-Person</span>
            </label>
            <label class="flex items-center gap-2 text-foreground">
              <input type="radio" name="mode" value="hybrid" required />
              <span>Hybrid (both online and in-person)</span>
            </label>
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-foreground mb-2">
            Education Level (optional, select all that apply)
          </label>
          <div class="space-y-2">
            <label class="flex items-center gap-2 text-foreground">
              <input type="checkbox" name="educationLevel" value="primary" />
              <span>Primary (Std 1-6)</span>
            </label>
            <label class="flex items-center gap-2 text-foreground">
              <input type="checkbox" name="educationLevel" value="secondary" />
              <span>Secondary (Form 1-5, SPM)</span>
            </label>
            <label class="flex items-center gap-2 text-foreground">
              <input type="checkbox" name="educationLevel" value="post-secondary" />
              <span>Post-Secondary (STPM, Diploma, Foundation)</span>
            </label>
            <label class="flex items-center gap-2 text-foreground">
              <input type="checkbox" name="educationLevel" value="tertiary" />
              <span>Tertiary (Degree, Master's, PhD)</span>
            </label>
            <label class="flex items-center gap-2 text-foreground">
              <input type="checkbox" name="educationLevel" value="all-levels" />
              <span>All Levels</span>
            </label>
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-foreground mb-2">
            Languages Available * (select at least one)
          </label>
          <div class="space-y-2">
            <label class="flex items-center gap-2 text-foreground">
              <input type="checkbox" name="languages" value="en" />
              <span>English</span>
            </label>
            <label class="flex items-center gap-2 text-foreground">
              <input type="checkbox" name="languages" value="ms" />
              <span>Bahasa Malaysia</span>
            </label>
            <label class="flex items-center gap-2 text-foreground">
              <input type="checkbox" name="languages" value="zh" />
              <span>Chinese</span>
            </label>
            <label class="flex items-center gap-2 text-foreground">
              <input type="checkbox" name="languages" value="ta" />
              <span>Tamil</span>
            </label>
          </div>
        </div>

        <div>
          <label for="tags" class="block text-sm font-medium text-foreground mb-1">
            Tags (optional)
          </label>
          <input
            type="text"
            id="tags"
            name="tags"
            class="w-full px-3 py-2 border border-border rounded-md bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-primary"
            placeholder="e.g., stem, scholarship, engineering, free (comma-separated)"
          />
          <p class="text-xs text-muted-foreground mt-1">Add descriptive tags separated by commas</p>
        </div>
      </div>

      <!-- Your Contact Info -->
      <div class="space-y-4">
        <h2 class="text-xl font-semibold text-foreground border-b border-border pb-2">Your Contact Info</h2>
        <p class="text-sm text-muted-foreground">We'll use this to contact you if we need clarification.</p>

        <div>
          <label for="submitterName" class="block text-sm font-medium text-foreground mb-1">
            Your Name
          </label>
          <input
            type="text"
            id="submitterName"
            name="submitterName"
            class="w-full px-3 py-2 border border-border rounded-md bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-primary"
            placeholder="Optional"
          />
        </div>

        <div>
          <label for="submitterEmail" class="block text-sm font-medium text-foreground mb-1">
            Your Email *
          </label>
          <input
            type="email"
            id="submitterEmail"
            name="submitterEmail"
            required
            class="w-full px-3 py-2 border border-border rounded-md bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-primary"
            placeholder="your@email.com"
          />
        </div>

        <div>
          <label for="submitterOrganization" class="block text-sm font-medium text-foreground mb-1">
            Organization (if applicable)
          </label>
          <input
            type="text"
            id="submitterOrganization"
            name="submitterOrganization"
            class="w-full px-3 py-2 border border-border rounded-md bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-primary"
            placeholder="Optional"
          />
        </div>

        <div>
          <label for="additionalNotes" class="block text-sm font-medium text-foreground mb-1">
            Additional Notes (optional)
          </label>
          <textarea
            id="additionalNotes"
            name="additionalNotes"
            rows="3"
            class="w-full px-3 py-2 border border-border rounded-md bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-primary"
            placeholder="Any other information we should know?"
          ></textarea>
        </div>

        <div class="flex items-start gap-3 p-4 rounded-lg border bg-surface-elevated">
          <input
            type="checkbox"
            id="isAnonymous"
            name="isAnonymous"
            class="mt-1 h-4 w-4 rounded border-gray-300"
          />
          <label for="isAnonymous" class="text-sm text-foreground">
            <span class="font-medium">Submit anonymously</span>
            <p class="text-muted-foreground">Your name will not be shown to the public. Admins can still see your identity.</p>
          </label>
        </div>
      </div>

      <!-- Submit Button -->
      <div class="pt-4">
        <button
          type="submit"
          form="resource-form"
          style="background-color: #0f766e; color: white; font-weight: 600;"
          class="w-full hover:bg-teal-800 py-3 px-4 rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed shadow-md hover:shadow-lg"
          id="submit-button"
        >
          Submit Resource for Review
        </button>
        <p class="text-xs text-gray-600 text-center mt-3">
          By submitting, you confirm that this information is accurate and you have the right to share it.
        </p>
      </div>

    </form>

    </div>
  </main>
  <Footer />
</Layout>

<script>
  // Resource submission form handler
  const form = document.getElementById('resource-form') as HTMLFormElement;
  const statusDiv = document.getElementById('form-status')!;
  const loadingDiv = document.getElementById('form-loading')!;
  const submitButton = document.getElementById('submit-button') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    // Hide previous status
    statusDiv.classList.add('hidden');
    
    // Validate required fields
    const resourceName = (document.getElementById('resourceName') as HTMLInputElement).value.trim();
    const provider = (document.getElementById('provider') as HTMLInputElement).value.trim();
    const url = (document.getElementById('url') as HTMLInputElement).value.trim();
    const description = (document.getElementById('description') as HTMLTextAreaElement).value.trim();
    const category = (document.getElementById('category') as HTMLSelectElement).value;
    const submitterEmail = (document.getElementById('submitterEmail') as HTMLInputElement).value.trim();
    
    // Get selected values
    const incomeGroups = Array.from(document.querySelectorAll('input[name="incomeGroups"]:checked')).map(el => (el as HTMLInputElement).value);
    const cost = (document.querySelector('input[name="cost"]:checked') as HTMLInputElement)?.value;
    const mode = (document.querySelector('input[name="mode"]:checked') as HTMLInputElement)?.value;
    const educationLevels = Array.from(document.querySelectorAll('input[name="educationLevel"]:checked')).map(el => (el as HTMLInputElement).value);
    const languages = Array.from(document.querySelectorAll('input[name="languages"]:checked')).map(el => (el as HTMLInputElement).value);
    const tags = (document.getElementById('tags') as HTMLInputElement).value.trim();
    
    // Validation
    if (!resourceName || !provider || !url || !description || !category || !submitterEmail) {
      showStatus('Please fill in all required fields', 'error');
      return;
    }
    
    if (description.length < 150) {
      showStatus('Description must be at least 150 characters', 'error');
      return;
    }
    
    if (incomeGroups.length === 0) {
      showStatus('Please select at least one income group', 'error');
      return;
    }
    
    if (!cost || !mode) {
      showStatus('Please select cost structure and delivery mode', 'error');
      return;
    }
    
    if (languages.length === 0) {
      showStatus('Please select at least one language', 'error');
      return;
    }
    
    // Show loading
    loadingDiv.classList.remove('hidden');
    submitButton.disabled = true;
    
    try {
      // Get auth token
      const { createClient } = await import('@supabase/supabase-js');
      const supabase = createClient(
        import.meta.env.PUBLIC_SUPABASE_URL,
        import.meta.env.PUBLIC_SUPABASE_PUBLISHABLE_KEY
      );
      const { data: { session } } = await supabase.auth.getSession();

      // Prepare submission data
      const submissionData = {
        type: 'resource',
        title: resourceName,
        description: description,
        url: url,
        categoryId: category,
        isAnonymous: (document.getElementById('isAnonymous') as HTMLInputElement).checked,
        metadata: {
          provider,
          income_groups: incomeGroups,
          cost_type: cost,
          delivery_mode: mode,
          education_levels: educationLevels,
          languages,
          tags: tags ? tags.split(',').map(t => t.trim()).filter(t => t) : [],
          submitter_email: submitterEmail,
          submitter_name: (document.getElementById('submitterName') as HTMLInputElement).value.trim(),
          submitter_organization: (document.getElementById('submitterOrganization') as HTMLInputElement).value.trim(),
          additional_notes: (document.getElementById('additionalNotes') as HTMLTextAreaElement).value.trim()
        }
      };

      // Build headers
      const headers: Record<string, string> = { 'Content-Type': 'application/json' };
      if (session?.access_token) {
        headers['Authorization'] = `Bearer ${session.access_token}`;
      }

      // Submit to API
      const response = await fetch('/api/contributions', {
        method: 'POST',
        headers,
        body: JSON.stringify(submissionData)
      });
      
      const result = await response.json();
      
      if (!response.ok) {
        throw new Error(result.error || 'Failed to submit');
      }
      
      // Success
      showStatus('Resource submitted successfully! It will be reviewed within 24-48 hours.', 'success');
      form.reset();
      
      // Redirect to success page after delay
      setTimeout(() => {
        window.location.href = '/contribute/success';
      }, 2000);
      
    } catch (error: any) {
      showStatus(error.message || 'Failed to submit. Please try again.', 'error');
    } finally {
      loadingDiv.classList.add('hidden');
      submitButton.disabled = false;
    }
  });
  
  function showStatus(message: string, type: 'success' | 'error') {
    statusDiv.textContent = message;
    statusDiv.className = `rounded-lg p-4 mb-4 ${
      type === 'success' 
        ? 'bg-green-100 border border-green-300 text-green-800' 
        : 'bg-red-100 border border-red-300 text-red-800'
    }`;
    statusDiv.classList.remove('hidden');
    statusDiv.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }
</script>
