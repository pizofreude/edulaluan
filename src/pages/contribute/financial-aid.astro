---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { Button } from '../../components/ui/button';
---

<Layout title="Submit Financial Aid Program - EduLaluan">
  <Header />

  <main class="min-h-screen bg-background">
  <div class="container mx-auto px-4 py-8 max-w-3xl">

    <!-- Header -->
    <div class="mb-8">
      <a href="/contribute" class="text-primary hover:text-primary-dark mb-4 inline-block">
        ← Back to Contribute
      </a>
      <h1 class="text-3xl font-bold text-foreground mb-2">
        💰 Submit Financial Aid Program
      </h1>
      <p class="text-muted-foreground">
        Share your scholarship, grant, bursary, or sponsorship program. Help students access education. All fields marked with * are required.
      </p>
    </div>

    <!-- Form -->
    <form
      id="financial-aid-form"
      class="bg-surface border rounded-lg p-6 space-y-6"
    >

      <!-- Status Messages -->
      <div id="form-status" class="hidden rounded-lg p-4"></div>
      <div id="form-loading" class="hidden text-center py-4">
        <div class="inline-block animate-spin rounded-full h-8 w-8 border-4 border-primary border-t-transparent"></div>
        <p class="mt-2 text-muted-foreground">Submitting your financial aid program...</p>
      </div>

      <!-- Program Information -->
      <div class="space-y-4">
        <h2 class="text-xl font-semibold text-foreground border-b pb-2">Program Information</h2>

        <div>
          <label for="programName" class="block text-sm font-medium text-foreground mb-1">
            Aid Program Name *
          </label>
          <input
            type="text"
            id="programName"
            name="programName"
            required
            class="w-full px-3 py-2 border border-border rounded-md bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-primary"
            placeholder="e.g., Community Education Scholarship 2026"
          />
        </div>

        <div>
          <label for="providerName" class="block text-sm font-medium text-foreground mb-1">
            Provider Name *
          </label>
          <input
            type="text"
            id="providerName"
            name="providerName"
            required
            class="w-full px-3 py-2 border border-border rounded-md bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-primary"
            placeholder="e.g., ABC Foundation / John Doe / XYZ Corporation"
          />
        </div>

        <div>
          <label for="providerType" class="block text-sm font-medium text-foreground mb-1">
            Provider Type *
          </label>
          <select 
            id="providerType" 
            name="providerType" 
            required 
            class="w-full px-3 py-2 border border-input bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-primary"
          >
            <option value="">-- Select Provider Type --</option>
            <option value="government">Government Agency</option>
            <option value="ngo">Private Foundation / NGO</option>
            <option value="corporate">Corporate / Company</option>
            <option value="individual">Individual Donor</option>
            <option value="institution">Educational Institution</option>
            <option value="religious">Religious Organization</option>
          </select>
        </div>

        <div>
          <label for="websiteUrl" class="block text-sm font-medium text-foreground mb-1">
            Website URL (optional for individuals)
          </label>
          <input 
            type="url" 
            id="websiteUrl" 
            name="websiteUrl" 
            class="w-full px-3 py-2 border border-input bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-primary"
            placeholder="https://example.com"
          />
        </div>

        <div>
          <label for="contactEmail" class="block text-sm font-medium text-foreground mb-1">
            Program Contact Email *
          </label>
          <input 
            type="email" 
            id="contactEmail" 
            name="contactEmail" 
            required 
            class="w-full px-3 py-2 border border-input bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-primary"
            placeholder="program@example.com"
          />
        </div>
      </div>

      <!-- Aid Details -->
      <div class="space-y-4">
        <h2 class="text-xl font-semibold text-foreground border-b pb-2">Aid Details</h2>
        
        <div>
          <label for="description" class="block text-sm font-medium text-foreground mb-1">
            Program Description *
          </label>
          <textarea 
            id="description" 
            name="description" 
            required 
            rows="6"
            minlength="150"
            maxlength="3000"
            class="w-full px-3 py-2 border border-input bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-primary"
            placeholder="Describe: Who is eligible? What is covered (tuition, living expenses, books)? How much (amount or percentage)? Duration (one-time, per semester, per year)?"
          ></textarea>
          <p class="text-xs text-muted-foreground mt-1">Minimum 150 characters. Be specific about coverage and eligibility.</p>
        </div>

        <div>
          <label for="aidCategory" class="block text-sm font-medium text-foreground mb-1">
            Aid Category *
          </label>
          <select 
            id="aidCategory" 
            name="aidCategory" 
            required 
            class="w-full px-3 py-2 border border-input bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-primary"
          >
            <option value="">-- Select Category --</option>
            <option value="scholarship">Scholarship (merit-based)</option>
            <option value="bursary">Bursary (need-based)</option>
            <option value="loan">Loan (repayable)</option>
            <option value="grant">Grant (non-repayable)</option>
            <option value="sponsorship">Sponsorship</option>
            <option value="other">Other</option>
          </select>
        </div>
      </div>

      <!-- Eligibility -->
      <div class="space-y-4">
        <h2 class="text-xl font-semibold text-foreground border-b pb-2">Eligibility Criteria</h2>
        
        <div>
          <label class="block text-sm font-medium text-foreground mb-2">
            Income Group * (select all that apply)
          </label>
          <div class="space-y-2">
            <label class="flex items-center gap-2">
              <input type="checkbox" name="incomeGroups" value="B40" class="rounded" />
              <span>B40 (&lt; RM4,850/month)</span>
            </label>
            <label class="flex items-center gap-2">
              <input type="checkbox" name="incomeGroups" value="M40" class="rounded" />
              <span>M40 (RM4,850-10,970/month)</span>
            </label>
            <label class="flex items-center gap-2">
              <input type="checkbox" name="incomeGroups" value="T20" class="rounded" />
              <span>T20 (&gt; RM10,970/month)</span>
            </label>
            <label class="flex items-center gap-2">
              <input type="checkbox" name="incomeGroups" value="all" class="rounded" />
              <span>All income groups</span>
            </label>
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-foreground mb-2">
            Education Level * (select all that apply)
          </label>
          <div class="space-y-2">
            <label class="flex items-center gap-2">
              <input type="checkbox" name="educationLevel" value="primary" />
              <span>Primary (Std 1-6)</span>
            </label>
            <label class="flex items-center gap-2">
              <input type="checkbox" name="educationLevel" value="secondary" />
              <span>Secondary (Form 1-5, SPM)</span>
            </label>
            <label class="flex items-center gap-2">
              <input type="checkbox" name="educationLevel" value="post-secondary" />
              <span>Post-Secondary (STPM, Diploma, Foundation)</span>
            </label>
            <label class="flex items-center gap-2">
              <input type="checkbox" name="educationLevel" value="tertiary" />
              <span>Tertiary (Degree, Master's, PhD)</span>
            </label>
          </div>
        </div>

        <div>
          <label for="fieldOfStudy" class="block text-sm font-medium text-foreground mb-1">
            Field of Study (optional)
          </label>
          <input 
            type="text" 
            id="fieldOfStudy" 
            name="fieldOfStudy" 
            class="w-full px-3 py-2 border border-input bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-primary"
            placeholder="e.g., Engineering, Medicine, Islamic Studies (or leave blank for all fields)"
          />
        </div>

        <div>
          <label for="otherRequirements" class="block text-sm font-medium text-foreground mb-1">
            Other Requirements (optional)
          </label>
          <textarea 
            id="otherRequirements" 
            name="otherRequirements" 
            rows="3"
            class="w-full px-3 py-2 border border-input bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-primary"
            placeholder="e.g., Minimum 3.5 CGPA, active in co-curricular activities, must be Bumiputera"
          ></textarea>
        </div>
      </div>

      <!-- Application Details -->
      <div class="space-y-4">
        <h2 class="text-xl font-semibold text-foreground border-b pb-2">Application Details</h2>
        
        <div>
          <label for="applicationUrl" class="block text-sm font-medium text-foreground mb-1">
            Application URL (optional)
          </label>
          <input 
            type="url" 
            id="applicationUrl" 
            name="applicationUrl" 
            class="w-full px-3 py-2 border border-input bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-primary"
            placeholder="https://apply.example.com"
          />
        </div>

        <div>
          <label for="applicationPeriod" class="block text-sm font-medium text-foreground mb-1">
            Application Period
          </label>
          <input 
            type="text" 
            id="applicationPeriod" 
            name="applicationPeriod" 
            class="w-full px-3 py-2 border border-input bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-primary"
            placeholder="e.g., January-March annually, Open year-round"
          />
        </div>

        <div>
          <label for="selectionProcess" class="block text-sm font-medium text-foreground mb-1">
            Selection Process (optional)
          </label>
          <textarea 
            id="selectionProcess" 
            name="selectionProcess" 
            rows="3"
            class="w-full px-3 py-2 border border-input bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-primary"
            placeholder="e.g., Interview + academic results + essay"
          ></textarea>
        </div>
      </div>

      <!-- Your Contact Info -->
      <div class="space-y-4">
        <h2 class="text-xl font-semibold text-foreground border-b pb-2">Your Contact Info</h2>
        
        <div>
          <label for="submitterName" class="block text-sm font-medium text-foreground mb-1">
            Your Name *
          </label>
          <input 
            type="text" 
            id="submitterName" 
            name="submitterName" 
            required 
            class="w-full px-3 py-2 border border-input bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-primary"
          />
        </div>

        <div>
          <label for="submitterRole" class="block text-sm font-medium text-foreground mb-1">
            Your Role *
          </label>
          <input 
            type="text" 
            id="submitterRole" 
            name="submitterRole" 
            required 
            class="w-full px-3 py-2 border border-input bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-primary"
            placeholder="e.g., Program Coordinator, Donor Representative"
          />
        </div>

        <div>
          <label for="submitterEmail" class="block text-sm font-medium text-foreground mb-1">
            Your Email *
          </label>
          <input 
            type="email" 
            id="submitterEmail" 
            name="submitterEmail" 
            required 
            class="w-full px-3 py-2 border border-input bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-primary"
            placeholder="your@email.com"
          />
        </div>

        <div>
          <label for="submitterPhone" class="block text-sm font-medium text-foreground mb-1">
            Your Phone (optional)
          </label>
          <input 
            type="tel" 
            id="submitterPhone" 
            name="submitterPhone" 
            class="w-full px-3 py-2 border border-input bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-primary"
            placeholder="+60123456789"
          />
        </div>
      </div>

      <!-- Verification -->
      <div class="space-y-3 p-4 bg-blue-50 rounded-md">
        <h3 class="font-semibold text-foreground">Verification</h3>
        <label class="flex items-start gap-2">
          <input type="checkbox" name="verifyAccuracy" required class="mt-1" />
          <span class="text-sm text-foreground">I confirm this information is accurate *</span>
        </label>
        <label class="flex items-start gap-2">
          <input type="checkbox" name="verifyAuthority" required class="mt-1" />
          <span class="text-sm text-foreground">I have authority to submit this information on behalf of the provider *</span>
        </label>
      </div>

      <!-- Submit Button -->
      <div class="pt-4">
        <button
          type="submit"
          id="submit-button"
          style="background-color: #b45309; color: white; font-weight: 600;"
          class="w-full hover:bg-amber-800 py-3 px-4 rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed shadow-md hover:shadow-lg"
        >
          Submit Financial Aid for Review
        </button>
        <p class="text-xs text-muted-foreground dark:text-gray-400 text-center mt-3">
          Your submission will be reviewed before publication to ensure legitimacy and accuracy.
        </p>
      </div>

    </form>

    </div>
  </main>
  <Footer />
</Layout>

<script>
  // Financial Aid submission form handler
  const form = document.getElementById('financial-aid-form') as HTMLFormElement;
  const statusDiv = document.getElementById('form-status')!;
  const loadingDiv = document.getElementById('form-loading')!;
  const submitButton = document.getElementById('submit-button') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    statusDiv.classList.add('hidden');
    
    const programName = (document.getElementById('programName') as HTMLInputElement).value.trim();
    const providerName = (document.getElementById('providerName') as HTMLInputElement).value.trim();
    const url = (document.getElementById('websiteUrl') as HTMLInputElement).value.trim();
    const description = (document.getElementById('description') as HTMLTextAreaElement).value.trim();
    const category = 'financial-aid';
    const submitterEmail = (document.getElementById('submitterEmail') as HTMLInputElement).value.trim();
    
    if (!programName || !providerName || !description || !submitterEmail) { showStatus('Please fill in all required fields', 'error'); return; }
    if (description.length < 150) { showStatus('Description must be at least 150 characters', 'error'); return; }
    
    const verifyAccuracy = (document.querySelector('input[name="verifyAccuracy"]') as HTMLInputElement)?.checked;
    const verifyAuthority = (document.querySelector('input[name="verifyAuthority"]') as HTMLInputElement)?.checked;
    if (!verifyAccuracy || !verifyAuthority) { showStatus('Please confirm both verification checkboxes', 'error'); return; }
    
    loadingDiv.classList.remove('hidden');
    submitButton.disabled = true;
    
    try {
      const submissionData = { type: 'financial_aid', title: programName, description, url: url || null, categoryId: category, metadata: { provider: providerName, submitter_email: submitterEmail } };
      const response = await fetch('/api/contributions', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(submissionData) });
      const result = await response.json();
      if (!response.ok) throw new Error(result.error || 'Failed to submit');
      
      showStatus('Financial aid program submitted successfully! It will be reviewed within 24-48 hours.', 'success');
      form.reset();
      setTimeout(() => { window.location.href = '/contribute/success'; }, 2000);
    } catch (error: any) {
      showStatus(error.message || 'Failed to submit. Please try again.', 'error');
    } finally {
      loadingDiv.classList.add('hidden');
      submitButton.disabled = false;
    }
  });
  
  function showStatus(message: string, type: 'success' | 'error') {
    statusDiv.textContent = message;
    statusDiv.className = `rounded-lg p-4 mb-4 ${
      type === 'success' 
        ? 'bg-green-100 border border-green-300 text-green-800' 
        : 'bg-red-100 border border-red-300 text-red-800'
    }`;
    statusDiv.classList.remove('hidden');
    statusDiv.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }
</script>
