---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { Button } from '../../components/ui/button';
---

<Layout title="Request a Feature - EduLaluan">
  <Header />

  <main class="min-h-screen bg-background">
  <div class="container mx-auto px-4 py-8 max-w-2xl">

    <!-- Header -->
    <div class="mb-8">
      <a href="/contribute" class="text-primary hover:text-primary-dark mb-4 inline-block">
        ← Back to Contribute
      </a>
      <h1 class="text-3xl font-bold text-foreground mb-2">
        💡 Request a Feature
      </h1>
      <p class="text-muted-foreground">
        Have an idea to improve EduLaluan? We'd love to hear it! All fields marked with * are required.
      </p>
    </div>

    <!-- Form -->
    <form
      id="feature-request-form"
      class="bg-surface border rounded-lg p-6 space-y-6"
    >

      <!-- Status Messages -->
      <div id="form-status" class="hidden rounded-lg p-4"></div>
      <div id="form-loading" class="hidden text-center py-4">
        <div class="inline-block animate-spin rounded-full h-8 w-8 border-4 border-primary border-t-transparent"></div>
        <p class="mt-2 text-muted-foreground">Submitting your feature request...</p>
      </div>

      <div>
        <label for="featureTitle" class="block text-sm font-medium text-foreground mb-1">
          Feature Title *
        </label>
        <input
          type="text"
          id="featureTitle"
          name="featureTitle"
          required
          class="w-full px-3 py-2 border border-border rounded-md bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-primary"
          placeholder="Brief one-line description"
        />
        <p class="text-xs text-muted-foreground mt-1">e.g., "Add filtering by language" or "Mobile app version"</p>
      </div>

      <div>
        <label for="featureDescription" class="block text-sm font-medium text-foreground mb-1">
          Detailed Description *
        </label>
        <textarea
          id="featureDescription"
          name="featureDescription"
          required
          rows="8"
          minlength="50"
          class="w-full px-3 py-2 border border-border rounded-md bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-primary"
          placeholder="Please describe:&#10;&#10;1. What feature would you like?&#10;2. Why would it be useful?&#10;3. How would it work?&#10;&#10;Be as detailed as possible to help us understand your idea."
        ></textarea>
        <p class="text-xs text-muted-foreground mt-1">Minimum 50 characters. The more detail, the better!</p>
      </div>

      <div>
        <label for="submitterEmail" class="block text-sm font-medium text-foreground mb-1">
          Your Email (optional)
        </label>
        <input
          type="email"
          id="submitterEmail"
          name="submitterEmail"
          class="w-full px-3 py-2 border border-border rounded-md bg-background text-foreground focus:outline-none focus:ring-2 focus:ring-primary"
          placeholder="your@email.com"
        />
        <p class="text-xs text-muted-foreground mt-1">In case we need clarification or want to update you on progress</p>
      </div>

      <!-- Submit Button -->
      <div class="pt-4">
        <button
          type="submit"
          id="submit-button"
          style="background-color: #0f766e; color: white; font-weight: 600;"
          class="w-full hover:bg-teal-800 py-3 px-4 rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed shadow-md hover:shadow-lg"
        >
          Submit Feature Request
        </button>
        <p class="text-xs text-gray-600 dark:text-gray-400 text-center mt-3">
          Thank you for helping us improve EduLaluan!
        </p>
      </div>

    </form>

    <!-- What happens next -->
    <div class="mt-8 p-4 bg-surface-elevated rounded-lg">
      <h3 class="font-display font-semibold text-foreground mb-2">What happens next?</h3>
      <p class="text-sm text-muted-foreground">
        Your feature request will be reviewed by our team. We'll consider factors like:
        feasibility, impact on users, alignment with our mission, and development resources.
        If we need more information, we'll reach out via email.
      </p>
    </div>

    </div>
  </main>
  <Footer />
</Layout>

<script>
  const form = document.getElementById('feature-request-form') as HTMLFormElement;
  const statusDiv = document.getElementById('form-status')!;
  const loadingDiv = document.getElementById('form-loading')!;
  const submitButton = document.getElementById('submit-button') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    statusDiv.classList.add('hidden');

    const featureTitle = (document.getElementById('featureTitle') as HTMLInputElement).value.trim();
    const description = (document.getElementById('featureDescription') as HTMLTextAreaElement).value.trim();
    const submitterEmail = (document.getElementById('submitterEmail') as HTMLInputElement).value.trim();

    if (!featureTitle || !description) { showStatus('Please fill in all required fields', 'error'); return; }
    if (description.length < 50) { showStatus('Description must be at least 50 characters', 'error'); return; }

    loadingDiv.classList.remove('hidden');
    submitButton.disabled = true;

    try {
      const submissionData = { type: 'feature_request', title: featureTitle, description, categoryId: null, metadata: { submitter_email: submitterEmail } };
      const response = await fetch('/api/contributions', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(submissionData) });
      const result = await response.json();
      if (!response.ok) throw new Error(result.error || 'Failed to submit');

      showStatus('Feature request submitted successfully! Thank you for your feedback.', 'success');
      form.reset();
      setTimeout(() => { window.location.href = '/contribute/success'; }, 2000);
    } catch (error: any) {
      showStatus(error.message || 'Failed to submit. Please try again.', 'error');
    } finally {
      loadingDiv.classList.add('hidden');
      submitButton.disabled = false;
    }
  });

  function showStatus(message: string, type: 'success' | 'error') {
    statusDiv.textContent = message;
    statusDiv.className = `rounded-lg p-4 mb-4 ${type === 'success' ? 'bg-green-100 border border-green-300 text-green-800' : 'bg-red-100 border border-red-300 text-red-800'}`;
    statusDiv.classList.remove('hidden');
    statusDiv.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }
</script>
