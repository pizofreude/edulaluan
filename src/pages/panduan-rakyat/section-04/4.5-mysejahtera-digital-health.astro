---
// Article 4.5: MySejahtera and Digital Health
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import Breadcrumb from '../../../components/panduan-rakyat/Breadcrumb';

const articleData = {
  sectionNumber: '04',
  sectionTitle: 'Health and Wellbeing',
  sectionIcon: '🏥',
  articleTitle: 'MySejahtera and Digital Health Services',
  articleDescription: 'Using digital platforms for healthcare access',
  colorRgb: '245, 158, 11',
  lastUpdated: 'March 2026',
};

const simpleContent = `
  <h2 id="what-is-mysejahtera">What is MySejahtera?</h2>
  <p>MySejahtera is a health app by the Malaysian government. It helps you access healthcare services digitally.</p>
  
  <h2 id="what-it-does">What it does:</h2>
  <ul>
    <li>📱 Book clinic appointments</li>
    <li>💉 View vaccination records</li>
    <li>🏥 Find nearby hospitals</li>
    <li>📋 Access health records</li>
    <li>💬 Teleconsultation (online doctor)</li>
  </ul>

  <h2 id="how-to-download">How to download:</h2>
  <ol>
    <li>Go to App Store or Google Play</li>
    <li>Search "MySejahtera"</li>
    <li>Download and install</li>
    <li>Register with phone number</li>
    <li>Enter IC number</li>
  </ol>

  <h2 id="is-it-free">Is it free?</h2>
  <ul>
    <li>✅ Yes, the app is free</li>
    <li>✅ Most features are free</li>
    <li>⚠️ Teleconsultation may have fees</li>
  </ul>

  <h2 id="other-digital-services">Other digital health services:</h2>
  <ul>
    <li>MyHealth (KKM portal)</li>
    <li>Online appointment booking</li>
    <li>e-Prescription</li>
  </ul>

  <h2 id="important-numbers">Important numbers:</h2>
  <ul>
    <li><strong>MySejahtera Helpdesk:</strong> In-app support</li>
    <li><strong>KKM Hotline:</strong> 03-8883 4000</li>
  </ul>
`;

const detailedContent = `
  <h2 id="overview">Overview</h2>
  <p>MySejahtera is Malaysia's official health application, developed by the government to provide digital healthcare services to citizens.</p>

  <h2 id="features">Key Features</h2>
  <h3>1. Clinic/Hospital Locator</h3>
  <ul>
    <li>Find nearest government clinics</li>
    <li>Find nearest hospitals</li>
    <li>View operating hours</li>
    <li>Get directions</li>
  </ul>

  <h3>2. Appointment Booking</h3>
  <ul>
    <li>Book clinic appointments online</li>
    <li>Schedule vaccination appointments</li>
    <li>Receive appointment reminders</li>
  </ul>

  <h3>3. Vaccination Records</h3>
  <ul>
    <li>View your vaccination history</li>
    <li>Download vaccination certificates</li>
    <li>Check upcoming vaccine dates</li>
  </ul>

  <h3>4. Teleconsultation</h3>
  <ul>
    <li>Consult doctors online</li>
    <li>Get medical advice remotely</li>
    <li>Receive e-prescriptions</li>
    <li>Medicine delivery available</li>
  </ul>

  <h3>5. Health Records</h3>
  <ul>
    <li>Access medical history</li>
    <li>View test results</li>
    <li>Track chronic conditions</li>
  </ul>

  <h2 id="how-to-register">How to Register</h2>
  <ol>
    <li><strong>Download app:</strong> App Store (iOS) or Google Play (Android)</li>
    <li><strong>Open app:</strong> Tap "Register"</li>
    <li><strong>Enter phone number:</strong> Receive OTP</li>
    <li><strong>Enter personal details:</strong> Name, IC number</li>
    <li><strong>Verify identity:</strong> Follow verification steps</li>
    <li><strong>Set password:</strong> Create secure password</li>
    <li><strong>Complete profile:</strong> Add emergency contacts, medical conditions</li>
  </ol>

  <h2 id="other-digital-services">Other Digital Health Services</h2>
  <h3>MyHealth Portal (KKM)</h3>
  <ul>
    <li>Website: myhealth.gov.my</li>
    <li>Health information and resources</li>
    <li>Disease prevention guides</li>
  </ul>

  <h3>Hospital-Specific Apps</h3>
  <ul>
    <li>Some hospitals have own apps</li>
    <li>Appointment booking</li>
    <li>Test results access</li>
  </ul>

  <h2 id="privacy-security">Privacy and Security</h2>
  <ul>
    <li>Data encrypted and secure</li>
    <li>Only accessible by you (password protected)</li>
    <li>Government-managed servers</li>
    <li>Complies with data protection laws</li>
  </ul>

  <h2 id="tips">Tips for Using</h2>
  <ul>
    <li>Keep app updated for latest features</li>
    <li>Use strong password</li>
    <li>Don't share login details</li>
    <li>Report any issues via in-app support</li>
  </ul>

  <h2 id="important-numbers">Important Contacts</h2>
  <ul>
    <li><strong>MySejahtera Helpdesk:</strong> In-app support</li>
    <li><strong>KKM Hotline:</strong> 03-8883 4000</li>
    <li><strong>Website:</strong> mysejahtera.malaysia.gov.my</li>
  </ul>
`;

const faqs = [
  {
    question: "Is MySejahtera mandatory?",
    answer: "No, MySejahtera is optional. However, it's highly recommended for convenient access to healthcare services and vaccination records."
  },
  {
    question: "Can foreigners use MySejahtera?",
    answer: "Yes, foreigners with valid Malaysian documents (passport, work permit, student visa) can register. Use passport number during registration."
  },
  {
    question: "Is teleconsultation free?",
    answer: "Basic teleconsultation may be free during certain programmes. Generally, there's a fee (RM30-RM100) depending on the service. Check app for current pricing."
  },
  {
    question: "What if I forget my password?",
    answer: "Use 'Forgot Password' feature in the app. You'll receive OTP on registered phone number to reset password."
  }
];

const headings = [
  { id: 'overview', title: 'Overview', level: 2 },
  { id: 'features', title: 'Key Features', level: 2 },
  { id: 'how-to-register', title: 'How to Register', level: 2 },
  { id: 'other-digital-services', title: 'Other Digital Services', level: 2 },
  { id: 'privacy-security', title: 'Privacy and Security', level: 2 },
];
---

<Layout title={`${articleData.articleTitle} | People's Guide | EduLaluan`}>
  <Header />
  <main class="min-h-screen bg-background">
    <section class="relative overflow-hidden py-section-lg border-b" style={{'--section-color': `rgb(${articleData.colorRgb})`,'border-bottom-color': `rgb(${articleData.colorRgb})`}}>
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl">
          <Breadcrumb items={[{label:'Home',href:'/'},{label:"People's Guide",href:'/panduan-rakyat'},{label:`Section ${articleData.sectionNumber}`,href:`/panduan-rakyat/section-${articleData.sectionNumber}`},{label:articleData.articleTitle}]} />
          <a href={`/panduan-rakyat/section-${articleData.sectionNumber}`} class="inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-primary transition-colors mb-6"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>Back to Section {parseInt(articleData.sectionNumber).toString()}</a>
          <div class="flex items-start gap-4 mt-6"><div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-xl text-3xl" style={{'backgroundColor': `rgb(${articleData.colorRgb})`,'color': 'white'}}>{articleData.sectionIcon}</div><div class="flex-1"><p class="text-sm font-medium text-primary mb-1 tracking-wide uppercase">Section {parseInt(articleData.sectionNumber).toString()}: {articleData.sectionTitle}</p><h1 class="font-display text-3xl sm:text-4xl font-bold text-foreground">{articleData.articleTitle}</h1><p class="text-lg text-muted-foreground mt-3">{articleData.articleDescription}</p></div></div>
        </div>
      </div>
    </section>
    <section class="py-section-md bg-surface">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex gap-8 max-w-6xl mx-auto">
          <div class="flex-1 min-w-0">
            <div class="mb-8">
              <div class="mb-6 flex gap-2 rounded-xl bg-muted p-1.5">
                <button id="tab-simple" class="flex flex-1 items-center justify-center gap-2 rounded-lg px-4 py-3 text-sm font-semibold transition-all duration-200 bg-surface-elevated text-primary shadow-sm" aria-pressed="true" data-tab="simple"><span class="text-xl">🧒</span><span>Simple</span></button>
                <button id="tab-detailed" class="flex flex-1 items-center justify-center gap-2 rounded-lg px-4 py-3 text-sm font-semibold transition-all duration-200 text-muted-foreground hover:text-foreground" aria-pressed="false" data-tab="detailed"><span class="text-xl">🧑</span><span>Detailed</span></button>
              </div>
              <div id="content-simple" class="prose-panduan max-w-none tab-content" set:html={simpleContent} />
              <div id="content-detailed" class="prose-panduan max-w-none tab-content hidden" set:html={detailedContent} />
            </div>
            <script is:inline>document.addEventListener('DOMContentLoaded',function(){const tabs=document.querySelectorAll('[data-tab]');const contents={simple:document.getElementById('content-simple'),detailed:document.getElementById('content-detailed')};tabs.forEach(function(tab){tab.addEventListener('click',function(){const selectedTab=this.getAttribute('data-tab');tabs.forEach(function(t){if(t.getAttribute('data-tab')===selectedTab){t.classList.add('bg-surface-elevated','text-primary','shadow-sm');t.classList.remove('text-muted-foreground','hover:text-foreground');t.setAttribute('aria-pressed','true');}else{t.classList.remove('bg-surface-elevated','text-primary','shadow-sm');t.classList.add('text-muted-foreground','hover:text-foreground');t.setAttribute('aria-pressed','false');}});if(selectedTab==='simple'){contents.simple.classList.remove('hidden');contents.detailed.classList.add('hidden');}else{contents.detailed.classList.remove('hidden');contents.simple.classList.add('hidden');}});});});</script>
            <div class="mt-12"><h2 class="font-display text-2xl font-bold text-foreground mb-6">Frequently Asked Questions</h2><div class="space-y-3">{faqs.map((faq)=>(<details class="group rounded-xl border bg-surface-elevated transition-all"><summary class="flex cursor-pointer items-center justify-between p-5 font-semibold text-foreground list-none">{faq.question}<svg class="h-5 w-5 text-muted-foreground transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg></summary><div class="px-5 pb-5 text-muted-foreground">{faq.answer}</div></details>))}</div></div>
            <div class="mt-12 pt-6 border-t border-border"><p class="text-sm text-muted-foreground"><strong>Last updated:</strong> {articleData.lastUpdated}</p></div>
          </div>
          <aside class="sticky top-24 hidden lg:block w-64 shrink-0"><nav class="space-y-1" aria-label="Table of contents"><h3 class="text-xs font-semibold text-muted-foreground uppercase tracking-wide mb-3">On This Page</h3>{headings.map((heading)=>(<a href={`#${heading.id}`} class="block py-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors" style={{paddingLeft:`${(heading.level-2)*12+12}px`}}>{heading.title}</a>))}</nav></aside>
        </div>
      </div>
    </section>
    <section class="py-section-md bg-background"><div class="container mx-auto px-4 sm:px-6 lg:px-8"><div class="mx-auto max-w-4xl"><div class="rounded-2xl border bg-surface-elevated p-6"><div class="flex items-center gap-3 text-muted-foreground"><svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg><p class="text-sm"><strong>Disclaimer:</strong> This guide provides general information only. Always verify with official sources for the most current information.</p></div></div></div></div></section>
  </main>
  <Footer />
</Layout>
<style>:root{--section-padding-lg:clamp(3rem,5vw + 1rem,5rem);--section-padding-md:clamp(2rem,3vw + 1rem,3rem)}.py-section-lg{padding-top:var(--section-padding-lg);padding-bottom:var(--section-padding-lg)}.py-section-md{padding-top:var(--section-padding-md);padding-bottom:var(--section-padding-md)}.prose-panduan{font-size:var(--text-base);line-height:var(--leading-relaxed);color:var(--foreground)}.prose-panduan h2{font-family:var(--font-display);font-size:var(--text-2xl);font-weight:700;margin-top:2.5rem;margin-bottom:1rem;color:var(--foreground)}.prose-panduan h3{font-family:var(--font-display);font-size:var(--text-xl);font-weight:600;margin-top:2rem;margin-bottom:0.75rem;color:var(--foreground)}.prose-panduan p{margin-bottom:1.25rem}.prose-panduan ul,.prose-panduan ol{margin-bottom:1.25rem;padding-left:1.5rem}.prose-panduan li{margin-bottom:0.5rem}.prose-panduan a{color:var(--primary);text-decoration:underline;text-underline-offset:2px}.prose-panduan a:hover{color:var(--primary-dark)}.prose-panduan strong{font-weight:600;color:var(--foreground)}.prose-panduan table{width:100%;border-collapse:collapse;margin:1.5rem 0}.prose-panduan th{background-color:var(--muted);font-weight:600;padding:0.75rem;border:1px solid var(--border)}.prose-panduan td{padding:0.75rem;border:1px solid var(--border)}.prose-panduan .bg-muted{background-color:var(--muted);padding:1rem;border-radius:0.5rem;margin:1.5rem 0}</style>
