---
// Article 4.1: KKM Overview
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AudienceTabs from '../../../components/AudienceTabs.astro';
import Breadcrumb from '../../../components/panduan-rakyat/Breadcrumb';

const articleData = {
  sectionNumber: '04',
  sectionTitle: 'Health and Wellbeing',
  sectionIcon: '🏥',
  articleTitle: 'Ministry of Health (KKM) Overview',
  articleDescription: 'Understanding Malaysian healthcare system and KKM services',
  colorRgb: '245, 158, 11',
  lastUpdated: 'March 2026',
};

const simpleContent = `
  <h2 id="what-is-kkm">What is KKM?</h2>
  <p>KKM (Kementerian Kesihatan Malaysia) is the Ministry of Health. They manage public healthcare in Malaysia.</p>
  
  <h2 id="what-they-do">What they do:</h2>
  <ul>
    <li>🏥 Run government hospitals and clinics</li>
    <li>💉 Manage vaccination programmes</li>
    <li>🔬 Control disease outbreaks</li>
    <li>📋 Set health policies</li>
  </ul>

  <h2 id="services">Services available:</h2>
  <ul>
    <li>General treatment at clinics</li>
    <li>Specialist treatment at hospitals</li>
    <li>Maternal and child health</li>
    <li>Vaccinations</li>
    <li>Health screenings</li>
  </ul>

  <h2 id="cost">Cost:</h2>
  <ul>
    <li><strong>Malaysians:</strong> RM1 at clinics, RM5 at hospitals</li>
    <li><strong>Non-citizens:</strong> Higher fees apply</li>
  </ul>

  <h2 id="important-numbers">Important numbers:</h2>
  <ul>
    <li><strong>KKM Hotline:</strong> 03-8883 4000</li>
    <li><strong>Website:</strong> moh.gov.my</li>
  </ul>
`;

const detailedContent = `
  <h2 id="overview">Overview</h2>
  <p>The Ministry of Health Malaysia (KKM) oversees the nation's public healthcare system, operating one of the most comprehensive healthcare networks in Southeast Asia.</p>

  <h2 id="healthcare-structure">Healthcare Structure</h2>
  <h3>Primary Care:</h3>
  <ul>
    <li>Klinik Kesihatan (Health Clinics)</li>
    <li>Klinik Pergigian (Dental Clinics)</li>
    <li>Klinik 1Malaysia (1Malaysia Clinics)</li>
  </ul>

  <h3>Secondary Care:</h3>
  <ul>
    <li>District Hospitals</li>
    <li>Specialist Hospitals</li>
  </ul>

  <h3>Tertiary Care:</h3>
  <ul>
    <li>State Hospitals</li>
    <li>National Specialist Centres</li>
  </ul>

  <h2 id="services">Services Available</h2>
  <h3>At Health Clinics:</h3>
  <ul>
    <li>General consultation and treatment</li>
    <li>Maternal and child health</li>
    <li>Family planning</li>
    <li>Immunisations</li>
    <li>Health screenings</li>
    <li>Chronic disease management</li>
  </ul>

  <h3>At Hospitals:</h3>
  <ul>
    <li>Emergency services (24/7)</li>
    <li>Specialist consultations</li>
    <li>Surgery and operations</li>
    <li>Inpatient care</li>
    <li>Diagnostic services (X-ray, lab tests)</li>
  </ul>

  <h2 id="how-to-access">How to Access Services</h2>
  <h3>At Clinics:</h3>
  <ol>
    <li>Walk-in during operating hours (no appointment needed)</li>
    <li>Register at counter with IC</li>
    <li>Pay RM1 (Malaysians) or RM5 (non-citizens)</li>
    <li>Wait for your turn</li>
    <li>See doctor and get treatment</li>
  </ol>

  <h3>At Hospitals:</h3>
  <ol>
    <li>For emergencies: Go directly to Emergency Department</li>
    <li>For specialist: Get referral letter from clinic first</li>
    <li>Register at counter</li>
    <li>Pay applicable fees</li>
  </ol>

  <h2 id="operating-hours">Operating Hours</h2>
  <table class="w-full border-collapse border border-border my-4">
    <thead><tr class="bg-muted"><th class="border border-border p-3 text-left">Facility Type</th><th class="border border-border p-3 text-left">Hours</th></tr></thead>
    <tbody>
      <tr><td class="border border-border p-3">Klinik Kesihatan</td><td class="border border-border p-3">Mon-Sat, 8 AM-5 PM (some until 10 PM)</td></tr>
      <tr><td class="border border-border p-3">Hospital Emergency</td><td class="border border-border p-3">24 hours, 7 days</td></tr>
      <tr><td class="border border-border p-3">Specialist Clinics</td><td class="border border-border p-3">Mon-Fri, 8 AM-5 PM (appointment only)</td></tr>
    </tbody>
  </table>

  <h2 id="important-numbers">Important Contacts</h2>
  <ul>
    <li><strong>KKM Hotline:</strong> 03-8883 4000</li>
    <li><strong>Website:</strong> moh.gov.my</li>
    <li><strong>Emergency:</strong> 999</li>
    <li><strong>Talian Kasih (counselling):</strong> 15999</li>
  </ul>
`;

const faqs = [
  {
    question: "Do I need an appointment for government clinics?",
    answer: "No, government health clinics operate on walk-in basis. Just bring your IC and arrive during operating hours. Specialist clinics require appointments and referral letters."
  },
  {
    question: "What if I can't afford private healthcare?",
    answer: "Government healthcare is heavily subsidised. Malaysians pay only RM1 at clinics and RM5 at hospitals. This includes consultation, basic treatment, and subsidised medications."
  },
  {
    question: "Can foreigners use government healthcare?",
    answer: "Yes, but at higher rates than citizens. Bring passport. Emergency treatment cannot be denied, but you'll be charged non-citizen rates."
  },
  {
    question: "Are medications free at government facilities?",
    answer: "Most medications are subsidised and included in the RM1/RM5 fee. Some specialised or non-formulary drugs may require payment."
  }
];

const headings = [
  { id: 'overview', title: 'Overview', level: 2 },
  { id: 'healthcare-structure', title: 'Healthcare Structure', level: 2 },
  { id: 'services', title: 'Services Available', level: 2 },
  { id: 'how-to-access', title: 'How to Access', level: 2 },
  { id: 'operating-hours', title: 'Operating Hours', level: 2 },
];
---

<Layout title={`${articleData.articleTitle} | People's Guide | EduLaluan`}>
  <Header />
  <main class="min-h-screen bg-background">
    <section class="relative overflow-hidden py-section-lg border-b" style={{'--section-color': `rgb(${articleData.colorRgb})`,'border-bottom-color': `rgb(${articleData.colorRgb})`}}>
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl">
          <Breadcrumb items={[{label:'Home',href:'/'},{label:"People's Guide",href:'/panduan-rakyat'},{label:`Section ${articleData.sectionNumber}`,href:`/panduan-rakyat/section-${articleData.sectionNumber}`},{label:articleData.articleTitle}]} />
          <a href={`/panduan-rakyat/section-${articleData.sectionNumber}`} class="inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-primary transition-colors mb-6"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>Back to Section {parseInt(articleData.sectionNumber).toString()}</a>
          <div class="flex items-start gap-4 mt-6"><div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-xl text-3xl" style={{'backgroundColor': `rgb(${articleData.colorRgb})`,'color': 'white'}}>{articleData.sectionIcon}</div><div class="flex-1"><p class="text-sm font-medium text-primary mb-1 tracking-wide uppercase">Section {parseInt(articleData.sectionNumber).toString()}: {articleData.sectionTitle}</p><h1 class="font-display text-3xl sm:text-4xl font-bold text-foreground">{articleData.articleTitle}</h1><p class="text-lg text-muted-foreground mt-3">{articleData.articleDescription}</p></div></div>
        </div>
      </div>
    </section>
    <section class="py-section-md bg-surface">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex gap-8 max-w-6xl mx-auto">
          <div class="flex-1 min-w-0">
            <AudienceTabs>
              <Fragment slot="simple" set:html={simpleContent} />
              <Fragment slot="detailed" set:html={detailedContent} />
            </AudienceTabs>
            <div class="mt-12"><h2 class="font-display text-2xl font-bold text-foreground mb-6">Frequently Asked Questions</h2><div class="space-y-3">{faqs.map((faq)=>(<details class="group rounded-xl border bg-surface-elevated transition-all"><summary class="flex cursor-pointer items-center justify-between p-5 font-semibold text-foreground list-none">{faq.question}<svg class="h-5 w-5 text-muted-foreground transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg></summary><div class="px-5 pb-5 text-muted-foreground">{faq.answer}</div></details>))}</div></div>
            <div class="mt-12 pt-6 border-t border-border"><p class="text-sm text-muted-foreground"><strong>Last updated:</strong> {articleData.lastUpdated}</p></div>
          </div>
          <aside class="sticky top-24 hidden lg:block w-64 shrink-0"><nav class="space-y-1" aria-label="Table of contents"><h3 class="text-xs font-semibold text-muted-foreground uppercase tracking-wide mb-3">On This Page</h3>{headings.map((heading)=>(<a href={`#${heading.id}`} class="block py-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors" style={{paddingLeft:`${(heading.level-2)*12+12}px`}}>{heading.title}</a>))}</nav></aside>
        </div>
      </div>
    </section>
    <section class="py-section-md bg-background"><div class="container mx-auto px-4 sm:px-6 lg:px-8"><div class="mx-auto max-w-4xl"><div class="rounded-2xl border bg-surface-elevated p-6"><div class="flex items-center gap-3 text-muted-foreground"><svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg><p class="text-sm"><strong>Disclaimer:</strong> This guide provides general information only. Always verify with official sources for the most current information.</p></div></div></div></div></section>
  </main>
  <Footer />
</Layout>
<style>:root{--section-padding-lg:clamp(3rem,5vw + 1rem,5rem);--section-padding-md:clamp(2rem,3vw + 1rem,3rem)}.py-section-lg{padding-top:var(--section-padding-lg);padding-bottom:var(--section-padding-lg)}.py-section-md{padding-top:var(--section-padding-md);padding-bottom:var(--section-padding-md)}.prose-panduan{font-size:var(--text-base);line-height:var(--leading-relaxed);color:var(--foreground)}.prose-panduan h2{font-family:var(--font-display);font-size:var(--text-2xl);font-weight:700;margin-top:2.5rem;margin-bottom:1rem;color:var(--foreground)}.prose-panduan h3{font-family:var(--font-display);font-size:var(--text-xl);font-weight:600;margin-top:2rem;margin-bottom:0.75rem;color:var(--foreground)}.prose-panduan p{margin-bottom:1.25rem}.prose-panduan ul,.prose-panduan ol{margin-bottom:1.25rem;padding-left:1.5rem}.prose-panduan li{margin-bottom:0.5rem}.prose-panduan a{color:var(--primary);text-decoration:underline;text-underline-offset:2px}.prose-panduan a:hover{color:var(--primary-dark)}.prose-panduan strong{font-weight:600;color:var(--foreground)}.prose-panduan table{width:100%;border-collapse:collapse;margin:1.5rem 0}.prose-panduan th{background-color:var(--muted);font-weight:600;padding:0.75rem;border:1px solid var(--border)}.prose-panduan td{padding:0.75rem;border:1px solid var(--border)}.prose-panduan .bg-muted{background-color:var(--muted);padding:1rem;border-radius:0.5rem;margin:1.5rem 0}</style>
