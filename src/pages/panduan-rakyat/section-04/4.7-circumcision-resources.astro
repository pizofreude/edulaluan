---
// Article 4.7: Circumcision Resources for Adult Reverts (Community Page)
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import Breadcrumb from '../../../components/panduan-rakyat/Breadcrumb';
import { CircumcisionWidget } from '../../../components/CircumcisionWidget';

const articleData = {
  sectionNumber: '04',
  sectionTitle: 'Health and Wellbeing',
  sectionIcon: '🏥',
  articleTitle: 'Circumcision Resources for Adult Reverts',
  articleDescription: 'Community-contributed experiences to help reverts navigate circumcision with confidence',
  colorRgb: '245, 158, 11',
  lastUpdated: 'March 2026',
};
---

<Layout title={`${articleData.articleTitle} | People's Guide | EduLaluan`}>
  <Header />

  <main class="min-h-screen bg-background">
    <!-- Article Header -->
    <section
      class="relative overflow-hidden py-section-lg border-b"
      style={{
        '--section-color': `rgb(${articleData.colorRgb})`,
        'border-bottom-color': `rgb(${articleData.colorRgb})`
      }}
    >
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl">
          <!-- Breadcrumb -->
          <Breadcrumb items={[
            { label: 'Home', href: '/' },
            { label: "People's Guide", href: '/panduan-rakyat' },
            { label: `Section ${articleData.sectionNumber}`, href: `/panduan-rakyat/section-${articleData.sectionNumber}` },
            { label: articleData.articleTitle }
          ]} />

          <!-- Back Button -->
          <a
            href={`/panduan-rakyat/section-${articleData.sectionNumber}`}
            class="inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-primary transition-colors mb-6"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            Back to Section {parseInt(articleData.sectionNumber).toString()}
          </a>

          <!-- Article Title -->
          <div class="flex items-start gap-4 mt-6">
            <div
              class="flex h-16 w-16 shrink-0 items-center justify-center rounded-xl text-3xl"
              style={{
                'backgroundColor': `rgb(${articleData.colorRgb})`,
                'color': 'white'
              }}
            >
              {articleData.sectionIcon}
            </div>
            <div class="flex-1">
              <p class="text-sm font-medium text-primary mb-1 tracking-wide uppercase">
                Section {parseInt(articleData.sectionNumber).toString()}: {articleData.sectionTitle}
              </p>
              <h1 class="font-display text-3xl sm:text-4xl font-bold text-foreground">
                {articleData.articleTitle}
              </h1>
              <p class="text-lg text-muted-foreground mt-3">
                {articleData.articleDescription}
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Editorial Notice - Female Sunat Framing -->
    <section class="py-section-md bg-surface">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl mx-auto">
          <div class="p-6 bg-teal-50 dark:bg-teal-900/20 border-2 border-teal-200 dark:border-teal-800 rounded-xl">
            <div class="flex items-start gap-4">
              <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-teal-100 dark:bg-teal-800 text-2xl">
            ⚕️
              </div>
              <div>
                <h2 class="font-display text-xl font-bold text-teal-900 dark:text-teal-100 mb-3">
                  Important: Understanding Female Sunat (Circumcision)
                </h2>
                <p class="text-teal-800 dark:text-teal-200 mb-3">
                  Female circumcision in Islam (<strong>sunat perempuan</strong>) involves <strong>ONLY a gentle needle prick</strong> on the clitoral hood. There is:
                </p>
                <ul class="space-y-2 mb-4">
                  <li class="flex items-center gap-2 text-teal-800 dark:text-teal-200">
                    <svg class="w-5 h-5 text-teal-600 dark:text-teal-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    <strong>NO cutting</strong>
                  </li>
                  <li class="flex items-center gap-2 text-teal-800 dark:text-teal-200">
                    <svg class="w-5 h-5 text-teal-600 dark:text-teal-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    <strong>NO tissue removal</strong>
                  </li>
                  <li class="flex items-center gap-2 text-teal-800 dark:text-teal-200">
                    <svg class="w-5 h-5 text-teal-600 dark:text-teal-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    <strong>NO lasting anatomical alteration</strong>
                  </li>
                </ul>
                <p class="text-teal-800 dark:text-teal-200 font-semibold">
                  This is fundamentally different from Female Genital Mutilation (FGM), which is harmful, condemned by international health bodies, and is NOT Islamic practice.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Community Submissions Widget -->
    <section class="py-section-md bg-background">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl mx-auto">
          <!-- Page Purpose -->
          <div class="mb-8 p-6 bg-muted rounded-xl">
            <h2 class="font-display text-xl font-bold text-foreground mb-3">
              About This Community Resource
            </h2>
            <p class="text-muted-foreground">
              This page provides community-contributed experiences to help adults — especially those new to Islam (reverts) — navigate circumcision with confidence. All submissions are experience-based and reviewed before publishing.
            </p>
          </div>

          <!-- Widget -->
          <CircumcisionWidget client:load />
        </div>
      </div>
    </section>

    <!-- Medical Disclaimer -->
    <section class="py-section-md bg-surface">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl mx-auto">
          <div class="rounded-2xl border bg-surface-elevated p-6">
            <div class="flex items-start gap-3 text-muted-foreground">
              <svg class="w-5 h-5 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div>
                <p class="text-sm mb-2">
                  <strong>Medical Disclaimer:</strong> The experiences shared on this page are personal accounts and do not constitute medical advice. Always consult with qualified healthcare professionals for personal medical decisions.
                </p>
                <p class="text-sm">
                  <strong>Information Accuracy:</strong> While we review all submissions, we cannot guarantee the accuracy of individual experiences. Clinic details, pricing, and procedures may change. Always verify directly with healthcare providers.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Related Resources -->
    <section class="py-section-md bg-background">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl mx-auto">
          <h2 class="font-display text-xl font-bold text-foreground mb-4">
            Related Resources
          </h2>
          <div class="grid gap-3 sm:grid-cols-3">
            <a
              href="/panduan-rakyat/section-04/4.1-ministry-of-health-kkm"
              class="p-4 border rounded-xl bg-surface-elevated hover:border-primary transition-colors group"
            >
              <div class="flex items-center gap-3">
                <span class="text-2xl">🏥</span>
                <div>
                  <p class="font-semibold text-foreground group-hover:text-primary transition-colors">4.1 Ministry of Health (KKM)</p>
                  <p class="text-xs text-muted-foreground">Healthcare overview</p>
                </div>
              </div>
            </a>
            <a
              href="/panduan-rakyat/section-04/4.2-public-vs-private-healthcare"
              class="p-4 border rounded-xl bg-surface-elevated hover:border-primary transition-colors group"
            >
              <div class="flex items-center gap-3">
                <span class="text-2xl">🏥</span>
                <div>
                  <p class="font-semibold text-foreground group-hover:text-primary transition-colors">4.2 Public vs Private Healthcare</p>
                  <p class="text-xs text-muted-foreground">Compare options</p>
                </div>
              </div>
            </a>
            <a
              href="/panduan-rakyat/section-04/4.3-government-hospitals"
              class="p-4 border rounded-xl bg-surface-elevated hover:border-primary transition-colors group"
            >
              <div class="flex items-center gap-3">
                <span class="text-2xl">🏥</span>
                <div>
                  <p class="font-semibold text-foreground group-hover:text-primary transition-colors">4.3 Government Hospitals</p>
                  <p class="text-xs text-muted-foreground">Public healthcare</p>
                </div>
              </div>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  :root {
    --section-padding-lg: clamp(3rem, 5vw + 1rem, 5rem);
    --section-padding-md: clamp(2rem, 3vw + 1rem, 3rem);
  }

  .py-section-lg {
    padding-top: var(--section-padding-lg);
    padding-bottom: var(--section-padding-lg);
  }

  .py-section-md {
    padding-top: var(--section-padding-md);
    padding-bottom: var(--section-padding-md);
  }
</style>
