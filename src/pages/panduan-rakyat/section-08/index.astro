---
// Section 08: Digital and Online Safety - Hub Page

import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import Breadcrumb from '../../../components/panduan-rakyat/Breadcrumb';

const sectionNumber = '08';
const sectionTitle = 'Digital and Online Safety';
const sectionDescription = 'Scam prevention, data privacy, and ethical tech';
const sectionIcon = '🔒';
const colorRgb = '8, 145, 178';

const articles = [
  {
    slug: '8.1-cybersecurity-basics',
    title: 'Cybersecurity Basics',
    description: 'Protecting yourself online',
  },
  {
    slug: '8.2-online-privacy',
    title: 'Online Privacy',
    description: 'Managing your digital footprint',
  },
  {
    slug: '8.3-social-media-safety',
    title: 'Social Media Safety',
    description: 'Safe social networking practices',
  },
  {
    slug: '8.4-phishing-scam-prevention',
    title: 'Phishing and Scam Prevention',
    description: 'Recognizing and avoiding online scams',
  },
  {
    slug: '8.5-password-security',
    title: 'Password Security',
    description: 'Creating and managing strong passwords',
  },
  {
    slug: '8.6-safe-online-shopping',
    title: 'Safe Online Shopping',
    description: 'Shopping securely online',
  },
  {
    slug: '8.7-digital-footprint',
    title: 'Digital Footprint Management',
    description: 'Controlling your online presence',
  },
  {
    slug: '8.8-childrens-online-safety',
    title: "Children's Online Safety",
    description: 'Keeping kids safe online',
  },
  {
    slug: '8.9-remote-work-security',
    title: 'Remote Work Security',
    description: 'Working from home safely',
  },
  {
    slug: '8.10-mobile-device-security',
    title: 'Mobile Device Security',
    description: 'Protecting your phone and tablet',
  },
  {
    slug: '8.11-cloud-storage-safety',
    title: 'Cloud Storage Safety',
    description: 'Secure cloud storage practices',
  },
  {
    slug: '8.12-digital-identity-protection',
    title: 'Digital Identity Protection',
    description: 'Preventing identity theft',
  },
  {
    slug: '8.13-creators',
    title: 'Recommended Creators and Channels on Digital Safety',
    description: 'Trusted sources for cybersecurity info',
  },
];

const formattedSectionNum = parseInt(sectionNumber).toString();
---

<Layout title={`${sectionTitle} | People's Guide | EduLaluan`}>
  <Header />

  <main class="min-h-screen bg-background">
    <!-- Hero Section -->
    <section 
      class="relative overflow-hidden py-section-lg"
      style={{
        '--section-color': `rgb(${colorRgb})`,
        'background': `linear-gradient(135deg, rgb(${colorRgb})/0.1 0%, var(--background) 50%, var(--accent)/0.05 100%)`
      }}
    >
      <!-- Decorative batik pattern -->
      <div class="absolute inset-0 opacity-[0.03]" aria-hidden="true">
        <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <pattern id="sectionDiamond" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
              <path d="M20 0 L40 20 L20 40 L0 20 Z" fill="currentColor" stroke="none" />
            </pattern>
          </defs>
          <rect width="100%" height="100%" fill="url(#sectionDiamond)" class="text-primary" />
        </svg>
      </div>

      <div class="container relative mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl">
          <!-- Breadcrumb -->
          <Breadcrumb items={[
            { label: 'Home', href: '/' },
            { label: "People's Guide", href: '/panduan-rakyat' },
            { label: sectionTitle }
          ]} />

          <!-- Back Button -->
          <a
            href="/panduan-rakyat"
            class="inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-primary transition-colors mb-6"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            Back to People's Guide
          </a>

          <!-- Section Header -->
          <div class="flex items-start gap-4 mb-6">
            <div 
              class="flex h-20 w-20 shrink-0 items-center justify-center rounded-2xl text-4xl"
              style={{ 
                'backgroundColor': `rgb(${colorRgb})`,
                'color': 'white'
              }}
            >
              {sectionIcon}
            </div>
            <div>
              <p class="text-sm font-medium text-primary mb-1 tracking-wide uppercase">
                Section {formattedSectionNum}
              </p>
              <h1 class="font-display text-4xl sm:text-5xl font-bold text-foreground">
                {sectionTitle}
              </h1>
            </div>
          </div>

          <p class="text-lg text-muted-foreground max-w-3xl">
            {sectionDescription}
          </p>
        </div>
      </div>
    </section>

    <!-- Articles Grid -->
    <section class="py-section-md bg-surface">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="mb-10">
          <h2 class="font-display text-2xl font-bold text-foreground">
            Topics in This Section
          </h2>
          <p class="text-muted-foreground mt-2">
            {articles.length} {articles.length === 1 ? 'article' : 'articles'} available
          </p>
        </div>

        <div class="grid gap-6 md:grid-cols-2">
          {articles.map((article) => (
            <a
              href={`/panduan-rakyat/section-${sectionNumber}/${article.slug}`}
              class="group relative overflow-hidden rounded-2xl border-2 bg-surface-elevated transition-all duration-300 hover:shadow-xl hover:-translate-y-1"
              style={{
                '--section-color': `rgb(${colorRgb})`,
                'border-color': `rgb(${colorRgb})`
              }}
            >
              <!-- Batik accent corner -->
              <div 
                class="absolute top-0 right-0 h-16 w-16 opacity-30 transition-opacity group-hover:opacity-50"
                style={{
                  'background': `radial-gradient(circle at top right, rgb(${colorRgb}) 0%, transparent 70%)`
                }}
              />

              <div class="p-6">
                <h3 
                  class="mb-2 text-xl font-bold transition-colors group-hover:text-primary"
                  style={{ 'color': `rgb(${colorRgb})` }}
                >
                  {article.title}
                </h3>
                <p class="text-sm text-muted-foreground mb-4">
                  {article.description}
                </p>
                <div class="flex items-center justify-between">
                  <span 
                    class="inline-flex items-center rounded-full px-3 py-1 text-xs font-medium"
                    style={{
                      'backgroundColor': `rgb(${colorRgb})`,
                      'color': 'white'
                    }}
                  >
                    Read Article
                  </span>
                  <span 
                    class="text-sm font-medium transition-transform group-hover:translate-x-1"
                    style={{ 'color': `rgb(${colorRgb})` }}
                  >
                    Learn More →
                  </span>
                </div>
              </div>

              <!-- Bottom accent bar -->
              <div 
                class="h-1 w-full"
                style={{ 'backgroundColor': `rgb(${colorRgb})` }}
              />
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Quick Reference Box -->
    <section class="py-section-md bg-background">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-4xl">
          <div 
            class="rounded-2xl border-2 p-8 bg-surface-elevated"
            style={{
              '--section-color': `rgb(${colorRgb})`,
              'border-color': `rgb(${colorRgb})`
            }}
          >
            <div class="flex items-start gap-4">
              <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-primary/10 text-2xl">
                💡
              </div>
              <div>
                <h3 class="font-display text-xl font-bold text-foreground mb-2">
                  Quick Reference
                </h3>
                <p class="text-muted-foreground">
                  NSRC (scams): <strong>15999</strong> | MCMC Cyber999: <strong>1-800-888-999</strong> | Password tips: Use 12+ characters, mix letters/numbers/symbols | Enable 2FA everywhere
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  /* Section padding utilities */
  :root {
    --section-padding-lg: clamp(3rem, 5vw + 1rem, 5rem);
    --section-padding-md: clamp(2rem, 3vw + 1rem, 3rem);
  }

  .py-section-lg {
    padding-top: var(--section-padding-lg);
    padding-bottom: var(--section-padding-lg);
  }

  .py-section-md {
    padding-top: var(--section-padding-md);
    padding-bottom: var(--section-padding-md);
  }
</style>
