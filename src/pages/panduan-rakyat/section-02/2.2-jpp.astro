---
// Article 2.2: Industrial Relations Department (JPP)
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AudienceTabs from '../../../components/AudienceTabs.astro';
import Breadcrumb from '../../../components/panduan-rakyat/Breadcrumb';

const articleData = {
  sectionNumber: '02',
  sectionTitle: 'Work and Employment',
  sectionIcon: '💼',
  articleTitle: 'Industrial Relations Department (JPP)',
  articleDescription: 'Employment disputes and industrial relations',
  colorRgb: '37, 99, 235',
  lastUpdated: 'March 2026',
};

const simpleContent = `
  <h2 id="what-is-jpp">What is JPP?</h2>
  <p>JPP (Jabatan Perhubungan Perusahaan) is the Industrial Relations Department. They help solve disputes between workers and employers.</p>
  
  <h2 id="when-to-contact">When to contact JPP:</h2>
  <ul>
    <li>😔 You were fired unfairly</li>
    <li>😔 Your employer broke the employment contract</li>
    <li>😔 Trade union disputes</li>
    <li>😔 Collective agreement issues</li>
  </ul>

  <h2 id="how-to-file">How to file a claim:</h2>
  <ol>
    <li><strong>Try to settle first:</strong> Talk to your employer</li>
    <li><strong>If fails:</strong> File at JPP within 60 days</li>
    <li><strong>Bring documents:</strong> Employment contract, termination letter, IC</li>
    <li><strong>Conciliation:</strong> JPP officer helps both parties negotiate</li>
    <li><strong>If still fails:</strong> Case goes to Industrial Court</li>
  </ol>

  <h2 id="important-numbers">Important numbers:</h2>
  <ul>
    <li><strong>JPP Hotline:</strong> 03-8885 7500</li>
    <li><strong>Website:</strong> jpp.gov.my</li>
  </ul>
`;

const detailedContent = `
  <h2 id="overview">Overview</h2>
  <p>The Jabatan Perhubungan Perusahaan (JPP) or Industrial Relations Department handles trade disputes, unfair dismissal claims, and industrial relations matters. They promote harmonious employer-employee relationships through conciliation and mediation.</p>

  <h2 id="services">Services Provided</h2>
  <ul>
    <li><strong>Unfair Dismissal Claims:</strong> Workers claiming wrongful termination</li>
    <li><strong>Trade Disputes:</strong> Collective bargaining issues</li>
    <li><strong>Recognition Disputes:</strong> Union recognition by employers</li>
    <li><strong>Collective Agreements:</strong> Registration and interpretation</li>
    <li><strong>Retrenchment:</strong> Disputes over layoffs</li>
  </ul>

  <h2 id="unfair-dismissal">Unfair Dismissal Claims</h2>
  <h3>Grounds for Claim:</h3>
  <ul>
    <li>Termination without just cause or excuse</li>
    <li>Victimization for union activities</li>
    <li>Discriminatory dismissal</li>
    <li>Constructive dismissal (forced to resign)</li>
  </ul>

  <h3>Time Limit:</h3>
  <p><strong>Must file within 60 days</strong> from the date of dismissal. Late claims are generally not accepted unless there are exceptional circumstances.</p>

  <h3>Process:</h3>
  <ol>
    <li>File Form A at JPP office</li>
    <li>Conciliation meeting scheduled (4-6 weeks)</li>
    <li>If settlement reached: Case closed</li>
    <li>If no settlement: Referred to Industrial Court</li>
  </ol>

  <h2 id="important-numbers">Important Contacts</h2>
  <ul>
    <li><strong>Hotline:</strong> 03-8885 7500</li>
    <li><strong>Website:</strong> jpp.gov.my</li>
    <li><strong>Email:</strong> jpp@jpp.gov.my</li>
  </ul>
`;

const faqs = [
  {
    question: "How long do I have to file an unfair dismissal claim?",
    answer: "You must file within 60 days from the date of dismissal. Late claims are rarely accepted unless there are exceptional circumstances beyond your control."
  },
  {
    question: "Do I need a lawyer for JPP conciliation?",
    answer: "No, lawyers are not allowed at conciliation meetings. It's designed to be informal. However, you can consult a lawyer before and after the meeting."
  },
  {
    question: "What if conciliation fails?",
    answer: "If conciliation fails, the case is referred to the Industrial Court for a formal hearing and decision."
  },
  {
    question: "Can I claim back wages if I win?",
    answer: "Yes, the Industrial Court can award back wages (up to 24 months) and/or reinstatement if you win an unfair dismissal case."
  }
];

const headings = [
  { id: 'overview', title: 'Overview', level: 2 },
  { id: 'services', title: 'Services Provided', level: 2 },
  { id: 'unfair-dismissal', title: 'Unfair Dismissal Claims', level: 2 },
  { id: 'important-numbers', title: 'Important Contacts', level: 2 },
];
---

<Layout title={`${articleData.articleTitle} | People's Guide | EduLaluan`}>
  <Header />

  <main class="min-h-screen bg-background">
    <!-- Article Header -->
    <section 
      class="relative overflow-hidden py-section-lg border-b"
      style={{
        '--section-color': `rgb(${articleData.colorRgb})`,
        'border-bottom-color': `rgb(${articleData.colorRgb})`
      }}
    >
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl">
          <!-- Breadcrumb -->
          <Breadcrumb items={[
            { label: 'Home', href: '/' },
            { label: "People's Guide", href: '/panduan-rakyat' },
            { label: `Section ${articleData.sectionNumber}`, href: `/panduan-rakyat/section-${articleData.sectionNumber}` },
            { label: articleData.articleTitle }
          ]} />

          <!-- Back Button -->
          <a
            href={`/panduan-rakyat/section-${articleData.sectionNumber}`}
            class="inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-primary transition-colors mb-6"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            Back to Section {parseInt(articleData.sectionNumber).toString()}
          </a>

          <!-- Article Title -->
          <div class="flex items-start gap-4 mt-6">
            <div 
              class="flex h-16 w-16 shrink-0 items-center justify-center rounded-xl text-3xl"
              style={{ 
                'backgroundColor': `rgb(${articleData.colorRgb})`,
                'color': 'white'
              }}
            >
              {articleData.sectionIcon}
            </div>
            <div class="flex-1">
              <p class="text-sm font-medium text-primary mb-1 tracking-wide uppercase">
                Section {parseInt(articleData.sectionNumber).toString()}: {articleData.sectionTitle}
              </p>
              <h1 class="font-display text-3xl sm:text-4xl font-bold text-foreground">
                {articleData.articleTitle}
              </h1>
              <p class="text-lg text-muted-foreground mt-3">
                {articleData.articleDescription}
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Article Content -->
    <section class="py-section-md bg-surface">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex gap-8 max-w-6xl mx-auto">
          <!-- Main Content -->
          <div class="flex-1 min-w-0">
            <!-- Audience Tabs (Simple/Detailed) -->
            <AudienceTabs>
              <Fragment slot="simple" set:html={simpleContent} />
              <Fragment slot="detailed" set:html={detailedContent} />
            </AudienceTabs>

            <!-- FAQ Section -->
            <div class="mt-12">
              <h2 class="font-display text-2xl font-bold text-foreground mb-6">
                Frequently Asked Questions
              </h2>
              <div class="space-y-3">
                {faqs.map((faq) => (
                  <details
                    class="group rounded-xl border bg-surface-elevated transition-all"
                  >
                    <summary class="flex cursor-pointer items-center justify-between p-5 font-semibold text-foreground list-none">
                      {faq.question}
                      <svg
                        class="h-5 w-5 text-muted-foreground transition-transform group-open:rotate-180"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                      >
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                      </svg>
                    </summary>
                    <div class="px-5 pb-5 text-muted-foreground">
                      {faq.answer}
                    </div>
                  </details>
                ))}
              </div>
            </div>

            <!-- Last Updated -->
            <div class="mt-12 pt-6 border-t border-border">
              <p class="text-sm text-muted-foreground">
                <strong>Last updated:</strong> {articleData.lastUpdated}
              </p>
            </div>
          </div>

          <!-- Table of Contents (Sidebar) -->
          <aside class="sticky top-24 hidden lg:block w-64 shrink-0">
            <nav class="space-y-1" aria-label="Table of contents">
              <h3 class="text-xs font-semibold text-muted-foreground uppercase tracking-wide mb-3">
                On This Page
              </h3>
              {headings.map((heading) => (
                <a
                  href={`#${heading.id}`}
                  class="block py-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors"
                  style={{ paddingLeft: `${(heading.level - 2) * 12 + 12}px` }}
                >
                  {heading.title}
                </a>
              ))}
            </nav>
          </aside>
        </div>
      </div>
    </section>

    <!-- Navigation Footer -->
    <section class="py-section-md bg-background">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-4xl">
          <div class="rounded-2xl border bg-surface-elevated p-6">
            <div class="flex items-center gap-3 text-muted-foreground">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <p class="text-sm">
                <strong>Disclaimer:</strong> This guide provides general information only. Always verify with official sources for the most current information.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  /* Section padding utilities */
  :root {
    --section-padding-lg: clamp(3rem, 5vw + 1rem, 5rem);
    --section-padding-md: clamp(2rem, 3vw + 1rem, 3rem);
  }

  .py-section-lg {
    padding-top: var(--section-padding-lg);
    padding-bottom: var(--section-padding-lg);
  }

  .py-section-md {
    padding-top: var(--section-padding-md);
    padding-bottom: var(--section-padding-md);
  }

  /* Article Typography */
  .prose-panduan {
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--foreground);
  }

  .prose-panduan h2 {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 700;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: var(--foreground);
  }

  .prose-panduan h3 {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: var(--foreground);
  }

  .prose-panduan p {
    margin-bottom: 1.25rem;
  }

  .prose-panduan ul,
  .prose-panduan ol {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .prose-panduan li {
    margin-bottom: 0.5rem;
  }

  .prose-panduan a {
    color: var(--primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .prose-panduan a:hover {
    color: var(--primary-dark);
  }

  .prose-panduan strong {
    font-weight: 600;
    color: var(--foreground);
  }

  .prose-panduan table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
  }

  .prose-panduan th {
    background-color: var(--muted);
    font-weight: 600;
    padding: 0.75rem;
    border: 1px solid var(--border);
  }

  .prose-panduan td {
    padding: 0.75rem;
    border: 1px solid var(--border);
  }

  .prose-panduan .bg-muted {
    background-color: var(--muted);
    padding: 1rem;
    border-radius: 0.5rem;
    margin: 1.5rem 0;
  }
</style>
